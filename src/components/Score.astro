---
/*
 * Score — Verovio-rendered music notation, inline in essays.
 *
 * Usage inside an .mdx essay:
 *
 *   <Score slug="twinkle" />            — plays once, stops at end
 *   <Score slug="ii-V-I" loop />        — loops forever, click again to stop
 *
 * The component is a thin shell. All work (lazy Verovio load, synthesis,
 * scroll sync, staff-lines layer, overlay) lives in src/lib/score-player.ts.
 *
 * Stage layering (bottom → top):
 *   .score-staff-lines   — single stage-wide source of the 5 staff lines,
 *                          drawn once. Pan and overlay are stripped so
 *                          no overlap thickening is possible.
 *   .score-pan-mask      — wraps .score-pan in a non-transforming parent
 *                          so its mask-image stays in stage coordinates.
 *                          Left-edge fade zone makes notes fade out as
 *                          they scroll toward the overlay.
 *   .score-pan           — transforms (translateX) to scroll music past
 *                          the playhead.
 *   .score-frozen-overlay — clef/keysig/meter glyphs pinned at the left.
 *                          No background — pan is already masked to 0 in
 *                          this area, and the staff-lines layer is below.
 *   .score-playhead      — fixed vertical line.
 *   .score-hint          — "click to play" before first play.
 */
interface Props {
  slug: string;
  loop?: boolean;
  /** Fraction across the stage where the playhead sits (0 = left, 1 = right). */
  playhead?: number;
  /** Per-staff body height in px (5-line staff top→bottom). Stage height
   *  auto-adjusts so this number lands the same in every piece regardless
   *  of how much above-/below-staff annotation it carries. Default 40. */
  staffHeight?: number;
}

const { slug, loop, playhead = 0.22, staffHeight = 40 } = Astro.props;
---

<figure
  class="score"
  data-slug={slug}
  data-playhead={playhead}
  data-loop={loop ? '' : null}
  data-staff-height={staffHeight}
  style={`--score-h: 200px; --score-playhead: ${playhead * 100}%`}
>
  <div class="score-stage" role="button" tabindex="0" aria-label="play or pause score">
    <div class="score-pan-mask" aria-hidden="true">
      <div class="score-pan"></div>
    </div>
    <div class="score-blur-in" aria-hidden="true"></div>
    <div class="score-playhead" aria-hidden="true"></div>
    <div class="score-hint" aria-hidden="true">click to play</div>
  </div>
</figure>

<script>
  import { attachAllScores, detachAllScores } from '../lib/score';
  attachAllScores();
  document.addEventListener('astro:page-load', attachAllScores);
  document.addEventListener('astro:before-swap', detachAllScores);
</script>

<style>
  /* Verovio embeds SMuFL music characters (quarter-note glyph in
     "♩ = 144" tempo strings, dynamics modifiers like the small "p"
     before "dolcissimo") in `<tspan font-family="Leipzig">` inside
     pan text. Without the Leipzig font the browser falls back to the
     default serif and renders the SMuFL Private-Use codepoints as
     tofu boxes. Self-host the WOFF2 (already in /public/fonts/) so
     these inline music characters render the same in Chromium and
     Firefox without a third-party CDN dependency. */
  @font-face {
    font-family: 'Leipzig';
    src: url('/fonts/Leipzig.woff2') format('woff2');
    font-display: swap;
  }

  .score {
    margin: 2.2em 0;
    padding: 0;
  }

  .score-stage {
    position: relative;
    width: 100%;
    /* `--score-h` is the actual stage height: the inline style seeds it
       at 200px (initial render), then mountScore replaces it with a
       value computed from the measured staff body span so each staff
       lands at the author's `staffHeight` target. JS also enforces an
       80vh ceiling so an orchestral piece doesn't push past the
       viewport. No CSS-side viewport-width cap — narrow phones simply
       get a taller score that vertical-scrolls; clamping to 90vw would
       fight the staff-driven sizing and make staves uneven across
       pieces. */
    height: var(--score-h, 200px);
    overflow: hidden;
    cursor: grab;
    /* Prevent the browser's native touch-scrolling so our drag handler
       owns horizontal gestures. Vertical scrolling of the page still
       passes through because `touch-action: pan-y` allows it. */
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
    /* Global right-edge fade. Affects staff-lines, pan, overlay —
       everything inside the stage. This is what makes the staff lines
       fade in as they enter from the right. Pan then stacks ADDITIONAL
       right-edge fade so notes appear after staff lines; see the pan
       mask definition. */
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 4%, #000 93%, transparent 100%);
            mask-image: linear-gradient(90deg, transparent 0%, #000 4%, #000 93%, transparent 100%);
    background: transparent;
  }
  .score-stage:active {
    cursor: grabbing;
  }
  .score-stage:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 4px;
  }

  /* === Dedicated staff-lines layer ================================== */
  /* A fresh SVG at stage level with 5 horizontal lines. Single source of
     truth for staff lines — pan's SVGs and the overlay's SVG have their
     staff paths stripped so there's no way for two lines to overlap and
     read as a thicker line. */
  .score-stage :global(.score-staff-lines) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    /* Stronger dim than `--fg-dim`: structural lines are scaffolding,
       not content. ~36% effective alpha (var --fg-dim is 78%, mixed
       at 45% with transparent). Same shade applied below to ledger
       lines + bar lines so all three structural axes recede in
       lockstep. */
    color: color-mix(in srgb, var(--fg-dim) 45%, transparent);
  }
  .score-stage :global(.score-staff-lines line) {
    stroke: currentColor;
    stroke-width: 1;
    fill: none;
    vector-effect: non-scaling-stroke;
  }

  /* === Pan mask ===================================================== */
  /* Lives on this wrapper (not on .score-pan itself) so its gradient
     stays in stage coordinates — if it lived on .score-pan, every
     translateX would drag the fade along with the music.
     Three zones, left to right:
       - 0 → --mask-start:         opacity 0  (hidden under the overlay)
       - --mask-start → --mask-end: opacity 0→1 (fade in past overlay)
       - --mask-end → --pan-right:  opacity 1  (main visible area)
       - --pan-right → 100%:        opacity 1→0 (right-edge entrance fade,
           wider than the stage's own right fade so notes appear LATER
           than the staff lines)
     The result: as a note scrolls in from the right, staff lines appear
     first (via the stage mask, which fades in a narrower zone), then
     the note itself fades in with the blur-to-sharp handled by the
     .score-blur-in overlay. */
  .score-pan-mask {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: visible;
    /* Three zones, left to right:
         0 → mask-start            transparent (overlay area)
         mask-start → mask-end     fade transparent → opaque
         mask-end → 82%            opaque (music area)
         82% → 98%                 right-edge entrance fade
       The fade between mask-start and mask-end is what gives the
       gentle "音符淡出" — notes scrolling INTO the chrome ease their
       opacity down rather than snapping off. A persistent half-
       visible m1 tempo marking (e.g. "Allegretto") used to bleed
       through this zone because the shell included `.tempo` glyphs;
       that's now stripped from MEASURE_MUSIC_CLASSES so the only
       text crossing this fade is mid-piece annotations in transit. */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0,
      transparent var(--mask-start, 0px),
      #000 var(--mask-end, 0px),
      #000 82%,
      transparent 98%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0,
      transparent var(--mask-start, 0px),
      #000 var(--mask-end, 0px),
      #000 82%,
      transparent 98%
    );
  }

  .score-pan {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    /* `will-change: transform` plus `translate3d` in the rAF loop
       promote the pan to its own GPU layer so per-frame translations
       are pure compositor moves, not browser repaints. `contain` tells
       the engine that nothing outside the pan can affect or be affected
       by its layout/paint, freeing the rest of the page from
       invalidation when the pan transforms. Critical for long pieces
       where the pan SVG can be tens of thousands of px wide. */
    will-change: transform, opacity;
    contain: layout paint;
    backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
    opacity: 1;
    transition: opacity var(--reset-fade, 400ms) ease-out;
  }
  /* Applied when a finished non-loop score is being rewound. Pan fades
     out, JS snaps pausedAt to 0, then the class is removed so opacity
     transitions back to 1 — giving a clean "fade back to start" feel
     without any visible mid-score snap. */
  .score-pan.is-resetting {
    opacity: 0;
  }
  .score-pan :global(svg) {
    display: block;
    height: 100%;
    width: auto;
    /* Default ink: full-opacity --fg. `currentColor` cascades from this
       to every glyph (noteheads, beams, ties, accidentals, dynamics,
       clef changes, etc.) via SVG's inherited fill/stroke. Combined
       with render.ts's string-level rewrite of literal `fill="black"`
       / `stroke="black"` to `currentColor`, one root rule covers the
       whole long tail without per-class enumeration. Structural lines
       (staff lines, ledger lines, bar lines) override below to the
       dim variant so they read as background scaffolding under the
       solid-white musical content. */
    color: var(--fg);
    fill: currentColor;
    stroke: currentColor;
  }
  /* Structural scaffolding — recede so the music reads first. Ledger
     lines and bar lines pick up the same dim-of-dim treatment as the
     dedicated staff-lines layer above (~36% effective alpha) so all
     three line types read as one quiet background grid. */
  .score-pan :global(svg .ledgerLines),
  .score-pan :global(svg .barLine) {
    color: color-mix(in srgb, var(--fg-dim) 45%, transparent);
  }
  /* Pin direct SVG children of the pan to their natural width. Without
     this, flex-shrink (default 1) collapses them when pan's shrink-to-
     fit width can't accommodate the sum of all copies/tiles — the pan
     ends up sized to one child's intrinsic width and the SVGs each
     squeeze down to ~1/N. That broke loop scores at mount: tile0's
     bounding rect read ~600px instead of the natural ~1700, throwing
     `musicWidth` out of sync with the wrap math. */
  .score-pan > :global(svg) {
    flex-shrink: 0;
  }
  /* Pedal markings (Ped. text + the bracket showing range of depression).
     A dense piece like Ravel's Jeux d'eau has hundreds of these, and at
     small stage heights the bracket reads as a foreign trapezoid below
     the staves. Reduced opacity keeps them as a soft visual hint of
     pedaling activity without competing with the notes. */
  .score-pan :global(svg .pedal) {
    opacity: 0.45;
  }

  /* === Frozen header overlay ======================================== */
  /* Holds the clef + keysig + meter glyphs only. No staff lines (those
     are in .score-staff-lines). No background — the pan mask already
     drops music to zero opacity in this region, and the staff-lines
     layer sits below the overlay, so there's nothing to hide here.

     Internal structure: a single SVG with one shell skeleton, plus
     stacked `<g class="clef|keySig|meterSig">` layers per (staff, axis).
     Each layer is opacity 0 by default; the render loop toggles
     `.is-current` on the active layer per track. Independent crossfades
     per axis × staff — a clef change on staff 1 doesn't trigger any
     visual change on staves 0 and 2 or on the keysig/meter slots. */
  .score-stage :global(.score-frozen-overlay) {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }
  .score-stage :global(.score-frozen-overlay svg) {
    display: block;
    height: 100%;
    width: auto;
    /* Solid ink for chrome glyphs (clef, keysig, meter) — same
       full-opacity treatment as pan symbols. Descendant selector (not
       `> svg`) so the rule reaches Verovio's nested
       `<svg class="definition-scale">` too — without it, the inner
       SVG resets its color/fill context to the SVG default (black)
       and every glyph renders solid black against the dim page. */
    color: var(--fg);
    fill: currentColor;
    stroke: currentColor;
  }
  /* Default: every chrome layer hidden. Crossfade transitions on
     opacity are cheap (composite-only) in both Chromium and Firefox
     for SVG <g> elements. Clef + keysig get the long symmetric fade
     because the visual content meaningfully differs across layers
     (G ↔ F clef glyph; sharps ↔ flats stack); a brief overlap at 0.5
     opacity reads as a clean morph. */
  .score-stage :global(.score-frozen-overlay g.clef),
  .score-stage :global(.score-frozen-overlay g.keySig) {
    opacity: 0;
    transition: opacity 450ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .score-stage :global(.score-frozen-overlay g.clef.is-current),
  .score-stage :global(.score-frozen-overlay g.keySig.is-current) {
    opacity: 1;
  }
  /* Meter is asymmetric: outgoing disappears INSTANTLY, incoming fades
     in over 250ms. Why: every meter variant stacks at the same X, and
     all share the bottom digit "4" (4/4, 2/4, 3/4 → all "x/4"). A
     symmetric crossfade renders both glyphs at 0.5 opacity at the
     midpoint, which composes the top digits into a smudge that reads
     as "missing meter" while the same-position "4" sums to full
     opacity. The asymmetric version skips the overlap entirely — only
     one glyph is on screen at a time, and the brief in-fade keeps
     the swap from feeling like a hard cut. */
  .score-stage :global(.score-frozen-overlay g.meterSig) {
    opacity: 0;
    transition: opacity 0ms;
  }
  .score-stage :global(.score-frozen-overlay g.meterSig.is-current) {
    opacity: 1;
    transition: opacity 250ms ease-out;
  }
  /* Meter-slot slides horizontally when the active keysig's width
     changes (e.g. C → F# pushes the meter right by ~6 sharps' width).
     The transform attribute is rewritten by JS on keysig swap; this
     transition makes the slide smooth and keeps the meter visually
     attached to its keysig instead of jumping. */
  .score-stage :global(.score-frozen-overlay g.meter-slot) {
    transition: transform 450ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .score-stage :global(.score-frozen-overlay g.clef),
    .score-stage :global(.score-frozen-overlay g.keySig),
    .score-stage :global(.score-frozen-overlay g.meterSig),
    .score-stage :global(.score-frozen-overlay g.meter-slot) {
      transition: none;
    }
  }

  /* === Right-edge blur-in =============================================
     A thin overlay on the stage's right edge that applies a gradient
     backdrop-filter blur. Music scrolling in from the right passes
     through this zone and sharpens as it approaches the main area.
     Combined with the stage's outer opacity mask, notes fade + sharpen
     into visibility rather than snapping in. */
  .score-blur-in {
    position: absolute;
    top: 0;
    right: 0;
    width: 14%;
    height: 100%;
    pointer-events: none;
    z-index: 4;
    /* Mask: transparent at LEFT (no blur effect), opaque at RIGHT
       (full blur). Because this div only exists in the right 14% of
       the stage, the gradient means blur ramps from 0 at ~stage 86%
       up to full at the stage's right edge. */
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 100%);
            mask-image: linear-gradient(90deg, transparent 0%, #000 100%);
    -webkit-backdrop-filter: blur(3px);
            backdrop-filter: blur(3px);
  }
  @supports not (backdrop-filter: blur(1px)) {
    .score-blur-in { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .score-blur-in { display: none; }
  }
  /* Whenever the pan translates every frame (both playback and drag),
     backdrop-filter has to re-sample its backdrop per tick — that's the
     main cause of perceptible stutter. Suspend it whenever the pan is
     in motion; the blur comes back as soon as everything settles. */
  .score.is-playing .score-blur-in,
  .score-stage.is-dragging .score-blur-in {
    -webkit-backdrop-filter: none;
            backdrop-filter: none;
  }

  /* === Playhead ===================================================== */
  .score-playhead {
    position: absolute;
    top: 6%;
    bottom: 6%;
    width: 1px;
    background: color-mix(in srgb, var(--fg-dim) 35%, transparent);
    pointer-events: none;
    z-index: 3;
    transition: background 250ms ease;
  }
  .score.is-playing .score-playhead {
    background: var(--accent);
  }

  /* === Tempo overlay ================================================
     Small mono-font label at top-left showing the active tempo marking.
     Crossfade is driven by `.is-changing` — `setCurrent()` adds it,
     swaps text mid-fade, then removes it. Only mounted when the piece
     has more than one tempo (single-tempo scores skip the chrome). */
  .score-stage :global(.score-tempo-overlay) {
    position: absolute;
    top: 4px;
    left: 10px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    pointer-events: none;
    white-space: nowrap;
    opacity: 0.85;
    transition: opacity 180ms ease;
    z-index: 5;
  }
  .score-stage :global(.score-tempo-overlay.is-changing) {
    opacity: 0;
  }

  /* === Hint ========================================================= */
  .score-hint {
    position: absolute;
    right: 8%;
    bottom: 8%;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    pointer-events: none;
    transition: opacity 400ms ease;
    opacity: 0.7;
    z-index: 5;
  }
  .score.is-playing .score-hint {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .score-pan {
      transform: none !important;
      transition: none !important;
    }
    .score-stage {
      overflow: auto;
    }
  }
</style>
