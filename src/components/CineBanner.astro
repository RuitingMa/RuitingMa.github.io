---
interface Props {
  sources: string[];
  height?: number;
  blur?: number;
  /** Crossfade duration in ms. */
  fade?: number;
  /** Interval between source switches in ms (multi-source only). */
  interval?: number;
  class?: string;
}

const VIDEO_EXTS = new Set(['.mp4', '.webm', '.mov', '.ogg']);
function isVideo(src: string) {
  const dot = src.lastIndexOf('.');
  return dot !== -1 && VIDEO_EXTS.has(src.slice(dot).toLowerCase());
}

const {
  sources,
  height = 120,
  blur = 6,
  fade = 5000,
  interval = 8000,
  class: className,
} = Astro.props;

const single = sources.length === 1;

// Per-instance id for the SVG blur filter. We need SVG (not CSS
// `filter: blur()`) because CSS blur samples outside-the-element as
// transparent black, which produces an alpha-fading edge that leaks
// the page background. SVG `feGaussianBlur edgeMode="duplicate"`
// instead samples the nearest edge pixel, so the blur stays opaque
// up to the element's bounds. The random suffix avoids id collisions
// when multiple banners coexist on the same page.
const filterId = `cb-blur-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class:list={['cine-banner', className]}
  style={`--cb-h: ${height}px; --cb-filter: url(#${filterId}); --cb-fade: ${fade}ms;`}
  data-cb-fade={fade}
  data-cb-interval={interval}
>
  {/* edgeMode="duplicate" extends the source by repeating edge pixels
      during convolution, killing the alpha-fade edge that CSS
      `filter: blur()` produces. We leave the filter region at its
      default (-10%..110%) so the blur output has a halo of slack
      around the bbox — clipping it tight to 100% caused the bbox
      edge to fade visibly at sub-pixel positions. */}
  <svg width="0" height="0" aria-hidden="true" style="position:absolute">
    <filter id={filterId}>
      <feGaussianBlur stdDeviation={blur} edgeMode="duplicate" />
    </filter>
  </svg>
  <div class="cb-track">
    {single ? (
      <>
        {/* Two elements for seamless loop crossfade */}
        {isVideo(sources[0]) ? (
          <>
            <video class="cb-media cb-a" src={sources[0]} autoplay muted playsinline />
            <video class="cb-media cb-b" src={sources[0]} muted playsinline style="opacity:0" />
          </>
        ) : (
          <img class="cb-media" src={sources[0]} alt="" />
        )}
      </>
    ) : (
      sources.map((src, i) =>
        isVideo(src) ? (
          <video
            class="cb-media"
            data-index={i}
            src={src}
            autoplay
            loop
            muted
            playsinline
            style={i === 0 ? undefined : 'opacity:0'}
          />
        ) : (
          <img
            class="cb-media"
            data-index={i}
            src={src}
            alt=""
            style={i === 0 ? undefined : 'opacity:0'}
          />
        )
      )
    )}
  </div>
</div>

<script>
  function initBanners() {
    for (const banner of document.querySelectorAll<HTMLElement>('.cine-banner')) {
      if ((banner as any).__cbInit) continue;
      (banner as any).__cbInit = true;

      const fadeMs = Number(banner.dataset.cbFade) || 5000;
      const fadeSec = fadeMs / 1000;
      const trans = `opacity ${fadeMs}ms ease`;

      const a = banner.querySelector<HTMLVideoElement>('.cb-a');
      const b = banner.querySelector<HTMLVideoElement>('.cb-b');

      if (a && b) {
        let active = a;
        let standby = b;

        // The `autoplay` HTML attribute fires reliably on first load
        // but not on SPA-rendered video — Astro's ClientRouter swaps
        // DOM after the parser's autoplay heuristic has run, leaving
        // the new <video> paused on a blank frame. Kick it off
        // explicitly. Catch is for autoplay-policy rejections (rare
        // here since the video is muted, but defensive).
        a.play().catch(() => {});

        // Single-direction crossfade: `fading` (z-index 1) drops 1→0
        // while `incoming` (z-index 0) sits behind it at full opacity
        // the whole time. Cross-fading *both* opacities used to leak
        // the page bg through at the midpoint (each layer ~0.5 alpha,
        // composite ~0.75, ~25% darkening). Now only the top layer
        // animates; the layer beneath is already opaque and just gets
        // revealed. After the fade lands we swap inline z-index so the
        // next round repeats with roles reversed.
        function swap() {
          const fading = active;
          const incoming = standby;

          incoming.currentTime = 0;
          incoming.play();
          incoming.style.transition = 'none';
          incoming.style.opacity = '1';

          fading.style.transition = trans;
          fading.style.opacity = '0';

          setTimeout(() => {
            incoming.style.zIndex = '1';
            fading.style.zIndex = '0';
          }, fadeMs);

          active = incoming;
          standby = fading;
        }

        a.addEventListener('timeupdate', () => {
          if (active !== a) return;
          if (a.duration && a.currentTime >= a.duration - fadeSec) swap();
        });
        b.addEventListener('timeupdate', () => {
          if (active !== b) return;
          if (b.duration && b.currentTime >= b.duration - fadeSec) swap();
        });
        continue;
      }

      // Multi-source mode
      const items = banner.querySelectorAll<HTMLElement>('.cb-media');
      if (items.length <= 1) continue;

      const interval = Number(banner.dataset.cbInterval) || 8000;
      let cur = 0;

      const timer = setInterval(() => {
        const prev = items[cur];
        cur = (cur + 1) % items.length;
        const next = items[cur];
        // Same single-direction crossfade as the seamless-loop case:
        // snap incoming up to opacity 1 behind the outgoing layer (no
        // transition), fade the outgoing layer out, then swap z-index
        // once the fade has landed. See comment on `swap()` above for
        // why fading both layers leaks the page bg through.
        next.style.transition = 'none';
        next.style.opacity = '1';
        prev.style.transition = trans;
        prev.style.opacity = '0';
        setTimeout(() => {
          next.style.zIndex = '1';
          prev.style.zIndex = '0';
        }, fadeMs);
      }, interval);

      banner.addEventListener('astro:unmount', () => clearInterval(timer), { once: true });
    }
  }
  initBanners();
  document.addEventListener('astro:page-load', initBanners);
</script>

<style>
  .cine-banner {
    position: relative;
    width: 100%;
    height: var(--cb-h);
    overflow: hidden;
    /* Solid backing matching page bg. Chrome ships an incomplete
       implementation of `feGaussianBlur edgeMode="duplicate"`, so the
       blur edge can still alpha-fade and let underlying text bleed
       through. With the bg here, any leaked alpha resolves to the same
       color as the page bg behind the whole banner — invisible blend,
       no text leak. Firefox renders edgeMode correctly, in which case
       this layer is just dead weight. */
    background: var(--bg);
  }

  .cb-track {
    position: relative;
    width: 100%;
    height: 100%;
    /* Feathered edges. Two linear-gradient masks combined via
       mask-composite: intersect — opaque center where both axes are
       opaque, faded at any edge where either axis is transparent.
       Where the mask is transparent, .cine-banner's solid bg (matching
       the page bg) shows through, so the seam is invisible regardless
       of what scrolls behind. Linear falloff feels softer than the
       Gaussian shoulder of an inset box-shadow. */
    -webkit-mask-image:
      linear-gradient(to right, transparent, #000 10px, #000 calc(100% - 10px), transparent),
      linear-gradient(to bottom, transparent, #000 8px, #000 calc(100% - 8px), transparent);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, transparent, #000 10px, #000 calc(100% - 10px), transparent),
      linear-gradient(to bottom, transparent, #000 8px, #000 calc(100% - 8px), transparent);
    mask-composite: intersect;
  }

  .cb-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* SVG filter (declared inline above) keeps the blur opaque up to
       the element's edges, so we don't need transform: scale(1.08) to
       hide a fading-to-transparent halo. */
    filter: var(--cb-filter);
    z-index: 0;
  }
  /* Initial active layer sits on top so its fade-out reveals the next
     layer underneath. JS rotates the inline z-index after each fade. */
  .cb-a,
  .cb-media[data-index="0"] {
    z-index: 1;
  }
</style>
