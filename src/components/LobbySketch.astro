---
/*
 * Lobby sketch — 静水 / Still Waters
 *
 * Homepage-only ambient piece. Slow, sparse, event-driven: a dark expanse
 * where occasional ripples rise at random points and fade out.
 */
---

<canvas id="lobby"></canvas>

<script>
  // Lifecycle: see src/lib/sketch-lifecycle.ts.
  import { mountSketch } from '../lib/sketch-lifecycle';
  import { setupCanvas2D, resizeCanvas2D } from '../lib/canvas-utils';

  mountSketch(() => {
    const setup = setupCanvas2D('lobby');
    if (!setup) return;
    const { canvas, ctx, dpr } = setup;
    let { w, h } = resizeCanvas2D(canvas, ctx, dpr);
    function resize() { ({ w, h } = resizeCanvas2D(canvas, ctx, dpr)); }

    type Ripple = { cx: number; cy: number; born: number; strength: number };
    const ripples: Ripple[] = [];
    const LIFETIME = 7000;
    const MAX_RADIUS_RATIO = 0.22;
    const RING_COUNT = 4;
    const RING_STAGGER = 0.07;
    const EXPIRE_AT = 1 + (RING_COUNT - 1) * RING_STAGGER + 0.02;
    const GAP_MIN = 2200;
    const GAP_SPAN = 4800;

    let heat = 0;
    let t = 0;
    let lastNow = performance.now();
    let paused = false;
    let nextSpawnAt = 1500;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    for (let i = 0; i < 2; i++) {
      ripples.push({
        cx: Math.random() * w,
        cy: Math.random() * h,
        born: -Math.random() * LIFETIME * 0.5,
        strength: 1,
      });
    }

    function spawn(cx: number, cy: number, strength = 1) {
      ripples.push({ cx, cy, born: t, strength });
    }

    const onPointerDown = (e: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      spawn(e.clientX - rect.left, e.clientY - rect.top, 1.25);
    };
    canvas.addEventListener('pointerdown', onPointerDown);

    const onHeat = (e: Event) => {
      const detail = (e as CustomEvent).detail as { level: number };
      heat = Math.max(0, Math.min(1, detail?.level ?? 0));
    };
    const onPause = (e: Event) => {
      const detail = (e as CustomEvent).detail as { paused: boolean };
      paused = !!detail?.paused;
    };
    window.addEventListener('stage:heat', onHeat);
    window.addEventListener('stage:pause', onPause);
    window.addEventListener('resize', resize);

    function easeOut(u: number) {
      return 1 - Math.pow(1 - u, 2.2);
    }

    let rafId = 0;
    let aborted = false;

    // Reduced motion: render one still-pond frame (a few frozen ripples
    // mid-life) and return before rAF starts. Don't bind pointerdown —
    // there's no loop to draw new ripples.
    if (reduced) {
      canvas.removeEventListener('pointerdown', onPointerDown);
      ctx.fillStyle = '#0f0f10';
      ctx.fillRect(0, 0, w, h);
      const maxR = Math.min(w, h) * MAX_RADIUS_RATIO;
      const frozen = [
        { cx: w * 0.28, cy: h * 0.42, age: 0.35 },
        { cx: w * 0.68, cy: h * 0.66, age: 0.62 },
        { cx: w * 0.52, cy: h * 0.22, age: 0.18 },
      ];
      ctx.strokeStyle = '#E6E2D6';
      ctx.lineWidth = 0.7;
      for (const r of frozen) {
        for (let k = 0; k < RING_COUNT; k++) {
          const ringAge = r.age - k * RING_STAGGER;
          if (ringAge <= 0 || ringAge >= 1) continue;
          const eased = easeOut(ringAge);
          const radius = eased * maxR;
          ctx.globalAlpha = Math.sin(ringAge * Math.PI) * 0.34 * (1 - k * 0.18);
          ctx.beginPath();
          ctx.arc(r.cx, r.cy, radius, 0, Math.PI * 2);
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;
      return () => {
        aborted = true;
        window.removeEventListener('stage:heat', onHeat);
        window.removeEventListener('stage:pause', onPause);
        window.removeEventListener('resize', resize);
      };
    }

    function frame() {
      if (aborted) return;
      rafId = requestAnimationFrame(frame);

      const now = performance.now();
      // Cap dt at 100ms so returning from a backgrounded tab doesn't dump
      // `t` forward by seconds — which would (a) burst-spawn a pile of
      // ripples in one frame via the while-loop below, and (b) age every
      // active ripple past its lifetime instantly.
      let dt = now - lastNow;
      if (dt > 100) dt = 100;
      lastNow = now;
      if (!paused) t += dt;

      ctx.fillStyle = '#0f0f10';
      ctx.fillRect(0, 0, w, h);

      const maxR = Math.min(w, h) * MAX_RADIUS_RATIO;

      while (!paused && t >= nextSpawnAt) {
        spawn(Math.random() * w, Math.random() * h);
        const gap = (GAP_MIN + Math.random() * GAP_SPAN) * (1 - 0.65 * heat);
        nextSpawnAt = t + gap;
      }

      // Stroke color is constant; per-ring alpha goes through globalAlpha
      // so we aren't allocating a fresh `rgba(...)` string each ring each
      // frame (~1000/s on a busy frame) — those were the main GC hitches.
      ctx.strokeStyle = '#E6E2D6';
      ctx.lineWidth = 0.7;

      for (let i = ripples.length - 1; i >= 0; i--) {
        const r = ripples[i];
        const baseAge = (t - r.born) / LIFETIME;
        if (baseAge >= EXPIRE_AT) {
          ripples.splice(i, 1);
          continue;
        }

        for (let k = 0; k < RING_COUNT; k++) {
          const ringAge = baseAge - k * RING_STAGGER;
          if (ringAge <= 0 || ringAge >= 1) continue;

          const eased = easeOut(ringAge);
          const radius = eased * maxR * r.strength;
          const alpha = Math.sin(ringAge * Math.PI) * 0.34 * (1 - k * 0.18) * r.strength;

          ctx.globalAlpha = alpha;
          ctx.beginPath();
          ctx.arc(r.cx, r.cy, radius, 0, Math.PI * 2);
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;
    }
    frame();

    return () => {
      aborted = true;
      cancelAnimationFrame(rafId);
      window.removeEventListener('stage:heat', onHeat);
      window.removeEventListener('stage:pause', onPause);
      window.removeEventListener('resize', resize);
    };
  });
</script>

<style>
  canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--bg);
  }
</style>
