<canvas id="cell"></canvas>

<script>
  // Pendulum-on-circle Voronoi grid.
  //
  // ──────────────────────────────────────────────────────────────────
  // Architecture note: the inner ring decoration is rendered as a
  // signed-distance-field (SDF) over the Voronoi cells. Polygon-edge
  // representations are discontinuous in the seed positions (Voronoi
  // edges generate / cancel as cells exchange adjacency), so analytical
  // inset polygons jump topologically across frames. The SDF
  //
  //     SDF(p) = min_{j ≠ i} (|p − s_j|² − |p − s_i|²) / (2 |s_j − s_i|)
  //
  // depends only on seed positions, which move continuously.
  //
  // The per-pixel SDF inner loop is the dominant cost (profile shows
  // ~85% of frame self-time at ~38ms/frame). It's offloaded to a
  // dedicated worker (cell-sdf-worker.ts). Main runs physics + Voronoi
  // build + bbox extraction + crisp Voronoi-edge stroke; worker only
  // does the SDF inner loop. Two-buffer ping-pong over a transferable
  // Uint32Array means main and worker overlap — the displayed rings
  // are one frame stale from physics, which at this animation pace
  // is invisible.
  // ──────────────────────────────────────────────────────────────────
  //
  // Free-motion equation (no cursor):
  //
  //     ω₀(θ) = ω_base · (1 + A · cos(θ + φ))     -- angle-dependent target
  //     θ̈    = γ · (ω₀(θ) − θ̇)                   -- relaxation toward target
  //
  // Cursor adds a pendulum torque:
  //     θ̈ += -k(d) · sin(θ − θ_cursor),   k(d) = K_MAX · exp(-d/τ)
  //
  // Camera drifts at ~1 cell per 5s with a low-frequency heading.
  //
  // Lifecycle: see src/lib/sketch-lifecycle.ts.
  import { mountSketch } from '../lib/sketch-lifecycle';
  import { Delaunay } from 'd3-delaunay';
  // Vite's `?worker` suffix yields a default export that's a Worker
  // constructor; the worker entry is bundled as a separate chunk.
  import SdfWorkerCtor from '../lib/cell-sdf-worker.ts?worker';

  mountSketch(() => {
    const canvas = document.getElementById('cell') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    const dpr = window.devicePixelRatio || 1;
    // SDF runs in CSS-pixel space (not physical). On retina, drawImage
    // bilinear-upscales the SDF buffer to fill the dpr-scaled main
    // canvas; rings look slightly soft but the worker stays well under
    // the 16ms frame budget. A previous attempt at dpr-aware SDF
    // (4× pixels at dpr=2) saturated the worker and stalled the rings.
    let w = 0, h = 0;
    let CELL_SIZE = 80;

    // ----- Color setup -----
    function parseColor(s: string): [number, number, number] {
      s = s.trim();
      let m = s.match(/^#([0-9a-f]{6})$/i);
      if (m) return [parseInt(m[1].slice(0, 2), 16), parseInt(m[1].slice(2, 4), 16), parseInt(m[1].slice(4, 6), 16)];
      m = s.match(/^#([0-9a-f]{3})$/i);
      if (m) return [parseInt(m[1][0] + m[1][0], 16), parseInt(m[1][1] + m[1][1], 16), parseInt(m[1][2] + m[1][2], 16)];
      m = s.match(/^rgba?\(([^)]+)\)$/i);
      if (m) {
        const p = m[1].split(',').map((t) => parseFloat(t.trim()));
        return [p[0] | 0, p[1] | 0, p[2] | 0];
      }
      return [230, 226, 214];
    }
    const rootStyle = getComputedStyle(document.documentElement);
    const FG = parseColor(rootStyle.getPropertyValue('--fg'));
    const BG_STR = rootStyle.getPropertyValue('--bg').trim() || '#0f0f10';
    // Cell's tint per src/lib/sketches.ts is moss. The stage <aside>
    // sits outside the article that carries the tint-* class, so
    // var(--accent) on the canvas resolves to fg rather than moss —
    // we look up the moss accent directly. If Cell's tint changes in
    // the registry, update this too.
    const ACCENT = parseColor(rootStyle.getPropertyValue('--accent-moss'));
    const fgRgba = (a: number) => `rgba(${FG[0]},${FG[1]},${FG[2]},${a})`;
    const fgPacked = FG[0] | (FG[1] << 8) | (FG[2] << 16);

    // Per-cell tint as a translucent moss veil over BG. Each cell gets
    // a startAlpha sampled from a smooth 2-D noise (so adjacent cells
    // share regional means — opaque clusters and rare transparent
    // pockets, instead of uniform scatter). A cell sits at startAlpha
    // while its polygon is fully off-canvas; the moment the polygon's
    // bbox first overlaps the canvas the birth-clock starts and alpha
    // fades linearly to 0 across TINT_LIFETIME_MS. When the polygon
    // drifts back off-canvas (or the cell is pruned and re-enters) the
    // clock resets — every visual entry reads as a rebirth.
    //
    // The visibility test is on the polygon, not the seed's grid coord:
    // the polygon can clip a strip on-canvas while its seed sits in the
    // padding zone, and a grid-based test caused a visible alpha jump
    // at that boundary.
    const MAX_TINT          = 0.55;
    const TINT_GROUP_SCALE  = 4;     // cells per noise unit (larger → bigger groups)
    const TINT_BIAS         = 0.5;   // <1 biases toward opaque (rare transparent)
    const TINT_LIFETIME_MS  = 30000; // time to fade to full transparency
    // Momentum-driven alpha boost: cells with high |thetaDot| (typically
    // because the cursor's pendulum torque is acting on them) get an
    // additional veil on top of the time-faded base. Squared so quiet
    // cells barely respond and fast cells light up sharply.
    const MOMENTUM_REF      = 3.0;   // |thetaDot| (rad/s) at saturation
    const MOMENTUM_BOOST    = 0.5;   // peak additive alpha at saturation
    // Path-light flares: pick two random cells on the grid boundary
    // (padding-inclusive) with a minimum end-to-end span, trace a
    // Bresenham-grid line between them, and ignite cells along the way.
    // The line itself is 2 cells wide (the Bresenham trace + a single
    // cell offset on the perpendicular). Light then bleeds outward
    // perpendicular to the line, peak alpha decaying with distance and
    // each spread layer ignited a bit later than the one before — so
    // the flare reads as a moving glow that diffuses sideways. Multiple
    // paths can overlap; per-cell lit alpha takes max-blend, then
    // max-blends again with the veil + momentum boost.
    const PATH_SPAWN_INTERVAL_MS = 5000; // mean ms between spawns (Poisson)
    const PATH_STEP_MS           = 110;  // ms between successive cell ignitions along the line
    const PATH_FADE_MS           = 3500; // each cell's fade duration
    const PATH_FADE_GAMMA        = 0.5;  // <1 sustains brightness, falls fast at end (sqrt curve)
    const PATH_PEAK_ALPHA        = 0.70; // peak alpha at the line core (full opacity ≡ 1)
    const PATH_MIN_LENGTH        = 7;    // Chebyshev cells; below this we skip & retry
    const PATH_MAX_SPREAD        = 3;    // perpendicular cells the flare bleeds into
    const PATH_SPREAD_DECAY      = 0.60; // peak alpha ratio per cell of spread distance
    const PATH_SPREAD_STEP_MS    = 200;  // ms delay per cell of spread distance
    const PATH_LIT_KICK          = 2.0;  // angular accel (rad/s²) per unit lit alpha — drives the cell's pendulum

    // ----- Pre-rendered orbital point sprite (true exp decay) -----
    const DOT_HALF  = 11;
    const DOT_DECAY =  1.9;
    let dotCanvas: HTMLCanvasElement;

    function rebuildDotSprite() {
      const phys = DOT_HALF * 2 * dpr;
      dotCanvas = document.createElement('canvas');
      dotCanvas.width = phys;
      dotCanvas.height = phys;
      const dctx = dotCanvas.getContext('2d')!;
      // Approximate the previous exp(-r / DOT_DECAY) sprite with a
      // radial gradient fill rather than per-pixel putImageData. Mobile
      // Chrome rendered the ImageData path as horizontal colored stripes;
      // mobile Firefox rendered it as solid purple blocks. Gradient fills
      // are native and don't trip the same browser bugs, while the
      // multi-stop curve closely matches the original exponential halo.
      const cx = phys / 2;
      const cy = phys / 2;
      const radius = DOT_HALF * dpr;
      const grad = dctx.createRadialGradient(cx, cy, 0, cx, cy, radius);
      const N_STOPS = 12;
      for (let i = 0; i <= N_STOPS; i++) {
        const t = i / N_STOPS;
        const a = Math.exp(-(t * DOT_HALF) / DOT_DECAY);
        grad.addColorStop(t, `rgba(${FG[0]},${FG[1]},${FG[2]},${a})`);
      }
      dctx.fillStyle = grad;
      dctx.fillRect(0, 0, phys, phys);
    }

    // ----- SDF rendering constants & precomputed tables -----
    const FEATHER     = 0.75;
    const RING_DECAY  = 0.55;
    const PEAK        = 0.30;
    const MAX_RINGS   = 5;

    const LUT_SIZE      = 256;
    const FEATHER_RANGE = 5 * FEATHER;
    const LUT_SCALE     = LUT_SIZE / FEATHER_RANGE;
    const FEATHER_LUT   = new Float32Array(LUT_SIZE + 1);
    for (let i = 0; i <= LUT_SIZE; i++) {
      FEATHER_LUT[i] = i >= LUT_SIZE ? 0 : Math.exp(-(i / LUT_SCALE) / FEATHER);
    }
    const RING_FADES = new Float32Array(MAX_RINGS + 1);
    for (let k = 1; k <= MAX_RINGS; k++) {
      RING_FADES[k] = Math.exp(-(k - 1) * RING_DECAY) * PEAK;
    }

    let layerSpacing = 0;
    let skipDist     = 0;

    // ----- SDF render plumbing -----
    // sdfCanvas holds the most recent SDF render result for compositing
    // each frame. The worker writes into one of two pooled Uint32Arrays
    // (transferable, ping-ponged); on response we wrap the buffer as
    // ImageData and putImageData it onto sdfCanvas, then push the buffer
    // back into the pool.
    let sdfCanvas: HTMLCanvasElement;
    let sdfCtx: CanvasRenderingContext2D;
    const sdfBufferPool: Uint32Array[] = [];
    let sdfWorkerInflight = 0;
    let sdfHasFirstResult = false;
    let sdfSeqNo = 0;
    const worker = new SdfWorkerCtor();

    worker.addEventListener('message', (e: MessageEvent) => {
      const msg = e.data as { type: 'result'; seqNo: number; sdfBuffer: Uint32Array };
      if (msg.type !== 'result') return;
      sdfWorkerInflight--;

      // Wrap the worker-filled u32 buffer as an ImageData and blit onto
      // sdfCanvas. ImageData expects a Uint8ClampedArray view of the
      // same backing buffer — no copy.
      const u8 = new Uint8ClampedArray(msg.sdfBuffer.buffer);
      const img = new ImageData(u8, sdfCanvas.width, sdfCanvas.height);
      sdfCtx.putImageData(img, 0, 0);
      sdfHasFirstResult = true;

      // Recycle.
      sdfBufferPool.push(msg.sdfBuffer);
    });

    // ----- Persistent main-side buffers (grown on demand) -----
    let flatBuf         = new Float64Array(0);   // seed positions, [px, py] pairs
    let neighborData    = new Float32Array(0);   // packed [nx, ny, 1/(2|d|)] triples
    let neighborOffsets = new Uint32Array(0);
    let neighborCounts  = new Uint16Array(0);
    let bboxesBuf       = new Float32Array(0);   // [xMin, yMin, xMax, yMax] per cell

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      CELL_SIZE = Math.max(56, Math.min(96, Math.max(w, h) / 10));
      layerSpacing = CELL_SIZE * 0.13;
      skipDist     = (MAX_RINGS + 0.5) * layerSpacing + 4 * FEATHER;
      rebuildDotSprite();

      sdfCanvas = document.createElement('canvas');
      sdfCanvas.width = Math.max(1, Math.floor(w));
      sdfCanvas.height = Math.max(1, Math.floor(h));
      sdfCtx = sdfCanvas.getContext('2d')!;

      // Reset the SDF pool. Any inflight buffers are dropped on the
      // floor (their backing memory was transferred to the worker — when
      // it eventually replies we'll just discard the stale buffer in the
      // message handler since its size won't match the new sdfCanvas).
      sdfBufferPool.length = 0;
      sdfHasFirstResult = false;
      const pixelCount = sdfCanvas.width * sdfCanvas.height;
      // Two buffers — enough for a 1-frame pipeline (one in worker, one
      // available for the next post). A third would only help if the
      // worker were faster than main, which isn't the case here.
      sdfBufferPool.push(new Uint32Array(pixelCount));
      sdfBufferPool.push(new Uint32Array(pixelCount));
    }
    resize();

    // ----- Hash & noise -----
    const hashU32 = (a: number, b: number, salt: number) => {
      let h = ((a | 0) * 374761393 + (b | 0) * 668265263 + (salt | 0) * 1274126177) | 0;
      h = Math.imul(h ^ (h >>> 13), 1274126177);
      h = h ^ (h >>> 16);
      return h >>> 0;
    };
    const hash01  = (a: number, b: number, s: number) => hashU32(a, b, s) / 4294967295;
    const hashSym = (a: number, b: number, s: number) => hash01(a, b, s) * 2 - 1;
    const smoothstep = (t: number) => t * t * (3 - 2 * t);
    const noise1 = (x: number) => {
      const xi = Math.floor(x);
      const xf = x - xi;
      const u = smoothstep(xf);
      const a = hash01(xi, 0, 9001);
      const b = hash01(xi + 1, 0, 9001);
      return a * (1 - u) + b * u;
    };
    // Bilinearly-smoothed 2D noise — used to sample per-cell tint
    // alpha so adjacent cells share a regional mean (cluster-like
    // groups) rather than scattering uniformly.
    const noise2 = (x: number, y: number) => {
      const xi = Math.floor(x), yi = Math.floor(y);
      const xf = x - xi, yf = y - yi;
      const u = smoothstep(xf), v = smoothstep(yf);
      const a = hash01(xi,     yi,     4242);
      const b = hash01(xi + 1, yi,     4242);
      const c = hash01(xi,     yi + 1, 4242);
      const d = hash01(xi + 1, yi + 1, 4242);
      return (a * (1 - u) + b * u) * (1 - v) + (c * (1 - u) + d * u) * v;
    };

    // ----- Per-cell state -----
    type Cell = {
      theta: number;
      thetaDot: number;
      omegaBase: number;
      omegaAmp: number;
      omegaPhase: number;
      rFactor: number;
      birthTime: number;   // ms — -1 while polygon is fully off-canvas; set to now on first overlap
      startAlpha: number;  // peak fill alpha at birth, faded over time
    };
    const cells = new Map<string, Cell>();
    const cellKey = (i: number, j: number) => `${i},${j}`;

    function ensureCell(i: number, j: number): Cell {
      const k = cellKey(i, j);
      let c = cells.get(k);
      if (c) return c;
      const omegaMag = 0.05 + hash01(i, j, 1) * 0.40;
      const sign = hashSym(i, j, 2) >= 0 ? 1 : -1;
      const groupNoise = noise2(i / TINT_GROUP_SCALE, j / TINT_GROUP_SCALE);
      c = {
        theta: hash01(i, j, 3) * Math.PI * 2,
        thetaDot: omegaMag * sign,
        omegaBase: omegaMag * sign,
        omegaAmp: 0.7 + hash01(i, j, 5) * 1.0,
        omegaPhase: hash01(i, j, 6) * Math.PI * 2,
        rFactor: 0.7 + hash01(i, j, 4) * 0.15,
        birthTime: -1,
        startAlpha: Math.pow(groupNoise, TINT_BIAS) * MAX_TINT,
      };
      cells.set(k, c);
      return c;
    }

    function pruneCells(iMin: number, iMax: number, jMin: number, jMax: number) {
      for (const k of cells.keys()) {
        const idx = k.indexOf(',');
        const i = +k.slice(0, idx);
        const j = +k.slice(idx + 1);
        if (i < iMin || i > iMax || j < jMin || j > jMax) cells.delete(k);
      }
    }

    // ----- Path-light flares -----
    type PathCell = { litAt: number; peak: number };
    type PathAnim = {
      cells: Map<string, PathCell>;
      endTime: number;
    };
    const activePaths: PathAnim[] = [];

    function spawnPath(now: number, iMin: number, iMax: number, jMin: number, jMax: number) {
      const pickBoundary = (): [number, number] => {
        const side = Math.floor(Math.random() * 4);
        if (side === 0) return [iMin, jMin + Math.floor(Math.random() * (jMax - jMin + 1))];
        if (side === 1) return [iMax, jMin + Math.floor(Math.random() * (jMax - jMin + 1))];
        if (side === 2) return [iMin + Math.floor(Math.random() * (iMax - iMin + 1)), jMin];
        return         [iMin + Math.floor(Math.random() * (iMax - iMin + 1)), jMax];
      };
      // Reject endpoint pairs whose Chebyshev distance falls below
      // PATH_MIN_LENGTH so flares always span a substantial portion of
      // the grid. Bound the retry loop — for very narrow viewports the
      // constraint may be unsatisfiable; we just skip the spawn.
      let i0 = 0, j0 = 0, i1 = 0, j1 = 0;
      let found = false;
      for (let attempt = 0; attempt < 12; attempt++) {
        [i0, j0] = pickBoundary();
        [i1, j1] = pickBoundary();
        const cheb = Math.max(Math.abs(i1 - i0), Math.abs(j1 - j0));
        if (cheb >= PATH_MIN_LENGTH) { found = true; break; }
      }
      if (!found) return;

      // Per-path perpendicular: 90° rotation of the overall direction
      // sign vector. Constant across the path so the flare reads as a
      // single straight band rather than a zigzag of per-step perps.
      const sgnDI = Math.sign(i1 - i0);
      const sgnDJ = Math.sign(j1 - j0);
      const perpI = -sgnDJ;
      const perpJ =  sgnDI;

      // Bresenham trace from start to end.
      const linePath: { i: number; j: number }[] = [];
      const di = Math.abs(i1 - i0);
      const dj = Math.abs(j1 - j0);
      const si = i0 < i1 ? 1 : -1;
      const sj = j0 < j1 ? 1 : -1;
      let err = di - dj;
      let i = i0, j = j0;
      const maxSteps = di + dj + 2;
      while (linePath.length < maxSteps) {
        linePath.push({ i, j });
        if (i === i1 && j === j1) break;
        const e2 = 2 * err;
        if (e2 > -dj) { err -= dj; i += si; }
        if (e2 <  di) { err += di; j += sj; }
      }

      // Core of the band is 2 cells wide: d=0 is the Bresenham trace,
      // d=1 is one perpendicular step. Both ignite at the same moment
      // (no spread delay). For |d| beyond the core, distance from the
      // core grows by 1 per step on each side; that distance feeds both
      // the peak-alpha decay and the per-layer ignition delay so the
      // flare diffuses outward over time.
      const spreadDist = (d: number): number => {
        if (d === 0 || d === 1) return 0;
        return d > 1 ? d - 1 : -d;
      };
      const cells = new Map<string, PathCell>();
      let maxSpreadDist = 0;
      for (let s = 0; s < linePath.length; s++) {
        const p = linePath[s];
        for (let d = -PATH_MAX_SPREAD; d <= PATH_MAX_SPREAD + 1; d++) {
          const ci = p.i + d * perpI;
          const cj = p.j + d * perpJ;
          const dist = spreadDist(d);
          if (dist > maxSpreadDist) maxSpreadDist = dist;
          const peak = PATH_PEAK_ALPHA * Math.pow(PATH_SPREAD_DECAY, dist);
          const litAt = now + s * PATH_STEP_MS + dist * PATH_SPREAD_STEP_MS;
          const key = cellKey(ci, cj);
          const existing = cells.get(key);
          // Earliest non-zero peak wins — a cell touched by a later
          // step would otherwise overwrite the brighter earlier hit.
          if (!existing || peak > existing.peak) {
            cells.set(key, { litAt, peak });
          }
        }
      }
      activePaths.push({
        cells,
        endTime:
          now +
          (linePath.length - 1) * PATH_STEP_MS +
          maxSpreadDist * PATH_SPREAD_STEP_MS +
          PATH_FADE_MS,
      });
    }

    // ----- Pointer / pause / resize -----
    let mouseX = -9999, mouseY = -9999;
    const onPointerMove = (e: PointerEvent) => {
      const rect = canvas!.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    };
    const onPointerLeave = () => { mouseX = -9999; mouseY = -9999; };
    canvas.addEventListener('pointermove', onPointerMove);
    canvas.addEventListener('pointerleave', onPointerLeave);

    let paused = false;
    const onPause = (e: Event) => { paused = !!(e as CustomEvent).detail?.paused; };
    window.addEventListener('stage:pause', onPause);
    window.addEventListener('resize', resize);

    let camX = 0, camY = 0;
    const K_MAX = 2.0;
    const GAMMA = 0.15;

    let lastT = performance.now();
    let aborted = false;
    let rafId = 0;
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    function frame(now: number) {
      if (aborted) return;
      if (!reduced) rafId = requestAnimationFrame(frame);

      let dt = (now - lastT) / 1000;
      lastT = now;
      if (dt > 0.05) dt = 0.05;
      const stepDt = paused ? 0 : dt;

      const heading = noise1(now * 0.00003) * Math.PI * 2;
      const speed = CELL_SIZE / 5;
      camX += Math.cos(heading) * speed * stepDt;
      camY += Math.sin(heading) * speed * stepDt;

      const halfW = w / 2, halfH = h / 2;
      // Padding of 2 (not 1): cells at the visible edge then have all
      // their true Voronoi neighbors present in the diagram, so the
      // SDF's `min over neighbors` doesn't gain new terms (and shift
      // discontinuously) as a fresh cell scrolls into view.
      const iMin = Math.floor((camX - halfW) / CELL_SIZE) - 2;
      const iMax = Math.floor((camX + halfW) / CELL_SIZE) + 2;
      const jMin = Math.floor((camY - halfH) / CELL_SIZE) - 2;
      const jMax = Math.floor((camY + halfH) / CELL_SIZE) + 2;
      pruneCells(iMin, iMax, jMin, jMax);

      // Path-light: drop expired flares, then maybe spawn a fresh one.
      // Spawn probability is dt-scaled so the rate stays Poisson regardless
      // of frame timing.
      for (let pi = activePaths.length - 1; pi >= 0; pi--) {
        if (activePaths[pi].endTime < now) activePaths.splice(pi, 1);
      }
      if (Math.random() < (dt * 1000) / PATH_SPAWN_INTERVAL_MS) {
        spawnPath(now, iMin, iMax, jMin, jMax);
      }

      const mwx = mouseX + camX - halfW;
      const mwy = mouseY + camY - halfH;
      const mouseInside = mouseX > -9000;
      const K_DECAY = CELL_SIZE * 2.5;

      const cellCount = (iMax - iMin + 1) * (jMax - jMin + 1);
      const flatNeeded = 2 * cellCount;
      if (flatBuf.length < flatNeeded) flatBuf = new Float64Array(flatNeeded * 2);

      type V = { cx: number; cy: number; r: number; px: number; py: number; c: Cell; lit: number; fill: string; fillAlpha: number };
      const visible: V[] = [];
      let n = 0;

      for (let j = jMin; j <= jMax; j++) {
        for (let i = iMin; i <= iMax; i++) {
          const c = ensureCell(i, j);

          // Path-lit alpha for this cell at `now`. Computed here (before
          // physics integration) so it can both drive the pendulum kick
          // and be stored on V for the render pass — single lookup
          // instead of two. Non-linear fade: pow(1 - age/fade, gamma)
          // with gamma < 1 sustains brightness through most of fadeMs
          // and snaps off at the end.
          let curLit = 0;
          if (activePaths.length > 0) {
            const key = cellKey(i, j);
            for (let pi = 0; pi < activePaths.length; pi++) {
              const entry = activePaths[pi].cells.get(key);
              if (!entry) continue;
              const age = now - entry.litAt;
              if (age < 0 || age > PATH_FADE_MS) continue;
              const a = entry.peak * Math.pow(1 - age / PATH_FADE_MS, PATH_FADE_GAMMA);
              if (a > curLit) curLit = a;
            }
          }

          const cwx = (i + 0.5) * CELL_SIZE;
          const cwy = (j + 0.5) * CELL_SIZE;
          const cx  = cwx - camX + halfW;
          const cy  = cwy - camY + halfH;
          const r   = (CELL_SIZE / 2) * c.rFactor;

          if (stepDt > 0) {
            const omegaTarget = c.omegaBase * (1 + c.omegaAmp * Math.cos(c.theta + c.omegaPhase));
            let dd = GAMMA * (omegaTarget - c.thetaDot);
            if (mouseInside) {
              const dx = mwx - cwx;
              const dy = mwy - cwy;
              const d = Math.sqrt(dx * dx + dy * dy);
              const k = K_MAX * Math.exp(-d / K_DECAY);
              const tc = Math.atan2(dy, dx);
              dd += -k * Math.sin(c.theta - tc);
            }
            // Path-lit kick: angular accel proportional to current lit
            // alpha, in the cell's natural rotation direction. As the
            // flare advances, lit cells spin up; combined with the
            // existing momentum→alpha boost in the bbox loop, a lit
            // cell visibly rolls and stays bright via positive feedback.
            if (curLit > 0) {
              dd += Math.sign(c.omegaBase) * curLit * PATH_LIT_KICK;
            }
            c.thetaDot += dd * stepDt;
            c.theta    += c.thetaDot * stepDt;
          }

          const px = cx + r * Math.cos(c.theta);
          const py = cy + r * Math.sin(c.theta);
          flatBuf[n * 2]     = px;
          flatBuf[n * 2 + 1] = py;
          // fill / fillAlpha are filled in below, after Voronoi build,
          // when each cell's polygon-canvas overlap is known.
          visible.push({ cx, cy, r, px, py, c, lit: curLit, fill: '', fillAlpha: 0 });
          n++;
        }
      }

      const used = flatBuf.subarray(0, n * 2);
      const delaunay = new Delaunay(used);
      const voronoi = delaunay.voronoi([0, 0, w, h]);

      // ----- Build packed neighbor data + per-cell bboxes for the worker.
      // bboxes come from voronoi.cellPolygon(k) for tightness; conservative
      // bboxes derived from neighbor distances would inflate the worker's
      // pixel count by ~4× and dwarf any savings from skipping cellPolygon.
      if (neighborOffsets.length < n) {
        neighborOffsets = new Uint32Array(n * 2);
        neighborCounts  = new Uint16Array(n * 2);
      }
      if (bboxesBuf.length < n * 4) {
        bboxesBuf = new Float32Array(n * 8);
      }
      let off = 0;
      for (let k = 0; k < n; k++) {
        neighborOffsets[k] = off;
        let count = 0;
        const sx = used[k * 2];
        const sy = used[k * 2 + 1];
        for (const j of voronoi.neighbors(k)) {
          if (j < 0 || j >= n) continue;
          if (off + 3 > neighborData.length) {
            const grown = new Float32Array(Math.max(neighborData.length * 2, off + 3, 1024));
            grown.set(neighborData);
            neighborData = grown;
          }
          const njx = used[j * 2];
          const njy = used[j * 2 + 1];
          const ddx = njx - sx;
          const ddy = njy - sy;
          const sdx2 = 2 * Math.sqrt(ddx * ddx + ddy * ddy);
          neighborData[off]     = njx;
          neighborData[off + 1] = njy;
          neighborData[off + 2] = 1 / sdx2;
          off += 3;
          count++;
        }
        neighborCounts[k] = count;
      }

      const sdfW = sdfCanvas.width;
      const sdfH = sdfCanvas.height;
      for (let k = 0; k < n; k++) {
        const v = visible[k];
        const c = v.c;
        const polyRaw = voronoi.cellPolygon(k);
        if (!polyRaw) {
          bboxesBuf[k * 4]     = 0;
          bboxesBuf[k * 4 + 1] = 0;
          bboxesBuf[k * 4 + 2] = 0;
          bboxesBuf[k * 4 + 3] = 0;
          // No polygon at all → fully off-canvas; reset birth so the
          // next time this cell's polygon does overlap we count it as a
          // fresh entry rather than continuing the stale clock.
          c.birthTime = -1;
          continue;
        }
        let bbMinX = Infinity, bbMinY = Infinity, bbMaxX = -Infinity, bbMaxY = -Infinity;
        for (const p of polyRaw) {
          if (p[0] < bbMinX) bbMinX = p[0];
          if (p[0] > bbMaxX) bbMaxX = p[0];
          if (p[1] < bbMinY) bbMinY = p[1];
          if (p[1] > bbMaxY) bbMaxY = p[1];
        }
        // Lifecycle test: does the polygon's bbox overlap the canvas?
        // Grid-coord based tests (i,j vs onCanvas window) miss the case
        // where the seed grid is in the padding zone but the polygon
        // still clips a strip on-canvas — caused a visible alpha jump
        // (full padding-zone alpha → faded on-canvas alpha) at the edge.
        const polyVisible = bbMaxX > 0 && bbMinX < w && bbMaxY > 0 && bbMinY < h;
        if (polyVisible) {
          if (c.birthTime < 0) c.birthTime = now;
        } else {
          c.birthTime = -1;
        }
        const fade = c.birthTime < 0
          ? 1
          : Math.max(0, 1 - (now - c.birthTime) / TINT_LIFETIME_MS);
        const baseAlpha = c.startAlpha * fade;
        // Quadratic momentum boost — additive on top of base so even
        // fully decayed cells light up under the cursor.
        const m = Math.min(1, Math.abs(c.thetaDot) / MOMENTUM_REF);
        const boost = MOMENTUM_BOOST * m * m;
        // Path-light contribution was already computed in the visible
        // loop (so the same value drove the pendulum kick); reuse it
        // here as a max-blend over the veil + momentum base.
        v.fillAlpha = Math.max(Math.min(1, baseAlpha + boost), v.lit);
        v.fill = `rgba(${ACCENT[0]},${ACCENT[1]},${ACCENT[2]},${v.fillAlpha})`;

        bboxesBuf[k * 4]     = Math.max(0, Math.floor(bbMinX));
        bboxesBuf[k * 4 + 1] = Math.max(0, Math.floor(bbMinY));
        bboxesBuf[k * 4 + 2] = Math.min(sdfW, Math.ceil(bbMaxX));
        bboxesBuf[k * 4 + 3] = Math.min(sdfH, Math.ceil(bbMaxY));
      }

      // ----- Post the SDF pass to the worker, if the pool has capacity.
      // Pool depth 2 means we tolerate up to 2 in flight; once main
      // out-paces worker the pool empties and we just skip posting (the
      // displayed sdfCanvas keeps showing the most recent result, which
      // is at most ~30 ms stale at this animation pace).
      if (sdfBufferPool.length > 0 && sdfWorkerInflight < 2) {
        const sdfBuffer = sdfBufferPool.pop()!;
        if (sdfBuffer.length === sdfW * sdfH) {
          sdfSeqNo++;
          // Send subarrays of exact length so structured clone copies
          // only the live portion of each persistent buffer rather than
          // its growth-headroom remainder.
          worker.postMessage({
            type: 'compute',
            seqNo: sdfSeqNo,
            positions: used,                                          // length n*2
            neighborOffsets: neighborOffsets.subarray(0, n),
            neighborCounts:  neighborCounts.subarray(0, n),
            neighborData:    neighborData.subarray(0, off),
            bboxes:          bboxesBuf.subarray(0, n * 4),
            sdfBuffer,
            n, w: sdfW, h: sdfH,
            layerSpacing,
            featherRange: FEATHER_RANGE,
            lutScale:     LUT_SCALE,
            featherLut:   FEATHER_LUT,
            ringFades:    RING_FADES,
            maxRings:     MAX_RINGS,
            fgPacked,
            skipDist,
          }, [sdfBuffer.buffer]);
          sdfWorkerInflight++;
        } else {
          // Stale buffer from a previous canvas size — drop it.
        }
      }

      // ===== Render =====

      ctx.fillStyle = BG_STR;
      ctx.fillRect(0, 0, w, h);

      // ----- Layer 1: per-cell translucent moss veil -----
      // Each cell paints accent at noise-clustered alpha that linearly
      // fades over TINT_LIFETIME_MS from its hashed startAlpha to 0.
      // Cells fully decayed are skipped — fillStyle assignment + path
      // build cost more than the no-op fill itself.
      for (let k = 0; k < n; k++) {
        if (visible[k].fillAlpha < 0.005) continue;
        ctx.fillStyle = visible[k].fill;
        ctx.beginPath();
        voronoi.renderCell(k, ctx);
        ctx.fill();
      }

      // ----- Layer 2: SDF inner rings (worker output) -----
      // sdfCanvas is updated asynchronously by the worker.onmessage
      // handler; until the first response arrives, sdfCanvas is blank
      // (transparent), and drawImage is a no-op. After ~1 frame,
      // rings appear.
      if (sdfHasFirstResult) {
        ctx.drawImage(sdfCanvas, 0, 0, w, h);
      }

      // ----- Layer 3: grid lines -----
      ctx.strokeStyle = fgRgba(0.16);
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let i = iMin; i <= iMax + 1; i++) {
        const x = Math.round(i * CELL_SIZE - camX + halfW) + 0.5;
        ctx.moveTo(x, 0);
        ctx.lineTo(x, h);
      }
      for (let j = jMin; j <= jMax + 1; j++) {
        const y = Math.round(j * CELL_SIZE - camY + halfH) + 0.5;
        ctx.moveTo(0, y);
        ctx.lineTo(w, y);
      }
      ctx.stroke();

      // ----- Layer 4: orbital circles -----
      ctx.strokeStyle = fgRgba(0.22);
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (const v of visible) {
        ctx.moveTo(v.cx + v.r, v.cy);
        ctx.arc(v.cx, v.cy, v.r, 0, Math.PI * 2);
      }
      ctx.stroke();

      // ----- Layer 5: Voronoi edges (crisp) -----
      ctx.strokeStyle = fgRgba(0.85);
      ctx.lineWidth = 1.6;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.beginPath();
      voronoi.render(ctx);
      ctx.stroke();

      // ----- Layer 6: orbital points -----
      const blitSize = DOT_HALF * 2;
      for (const v of visible) {
        ctx.drawImage(dotCanvas, v.px - DOT_HALF, v.py - DOT_HALF, blitSize, blitSize);
      }
    }

    if (reduced) {
      // Reduced-motion: render a single static frame. Worker still runs
      // for that one pass — but since we only call frame() once we'll
      // miss the worker's reply. Render without rings on the static
      // pass.
      frame(performance.now());
      aborted = true;
    } else {
      rafId = requestAnimationFrame(frame);
    }

    return () => {
      aborted = true;
      cancelAnimationFrame(rafId);
      worker.terminate();
      canvas.removeEventListener('pointermove', onPointerMove);
      canvas.removeEventListener('pointerleave', onPointerLeave);
      window.removeEventListener('stage:pause', onPause);
      window.removeEventListener('resize', resize);
    };
  });
</script>

<style>
  canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--bg);
    /* Claim touch gestures for the canvas; users scroll the prose
       column on the right (or below, on portrait mobile). */
    touch-action: none;
  }
</style>
