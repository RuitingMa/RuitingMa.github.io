---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbySketch from '../components/LobbySketch.astro';
---

<BaseLayout title="沉得太深" description="找不到这一页。它或许在海的另一侧。">
  <LobbySketch slot="stage" />

  <article class="tint-mist">
    <p class="code enter" style="--i: 0;">404 / NOT FOUND</p>
    <h1 class="enter" style="--i: 1;">沉&nbsp;得&nbsp;太&nbsp;深</h1>
    <p class="enter" style="--i: 2;">
      这一页不在海面，也没在海底的索引里。<br />
      也许它从未存在，也许它已经漂走。
    </p>
    <p class="back enter" style="--i: 3;">
      <a href="/" class="writ">← 回到眠海</a>
    </p>
  </article>
</BaseLayout>

<style>
  .code {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--accent);
    font-size: 0.7rem;
    margin: 0 0 3.5em;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 2.4rem;
    letter-spacing: 0.12em;
    margin: 0 0 1.2em;
    line-height: 1.25;
  }
  p {
    color: var(--fg-dim);
  }
  .back {
    margin-top: 3em;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
  }
  .back a {
    text-decoration: none;
  }
</style>
