---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbySketch from '../components/LobbySketch.astro';
import CineBanner from '../components/CineBanner.astro';
import { getCollection } from 'astro:content';
import { SKETCHES } from '../lib/sketches';

// Sketches remain hand-authored .astro pages (their layouts are bespoke,
// so a shared template fights them). The registry lives in src/lib/sketches.ts
// so each sketch page can import `isDraft` and gate itself in PROD.
// `draft` is uniform with the essay shape below so the listing template
// can render the "草稿" marker without caring which collection it came from.
const sketches = SKETCHES
  .filter((s) => import.meta.env.DEV || s.published)
  .map((s) => ({ ...s, draft: !s.published }));

// Long-form essays come from the content collection.
const essayEntries = await getCollection('essays', (e) => import.meta.env.DEV || e.data.published);
const essays = essayEntries.map((e) => ({
  href: `/essays/${e.id}/`,
  title: e.data.title,
  date: e.data.date,
  kind: e.data.kind,
  summary: e.data.summary,
  draft: !e.data.published,
}));

// Date desc, tie-break by href so order is deterministic. Essays sort
// before sketches on the same date because 'essays/' < 'sketches/'.
const entries = [...sketches, ...essays].sort((a, b) => {
  if (a.date !== b.date) return a.date < b.date ? 1 : -1;
  return a.href < b.href ? -1 : 1;
});

// Single source of truth: the same px feeds both the CineBanner prop
// and the CSS var that the banner-wrap's sticky `top` calc consumes.
const BANNER_H = 120;
---

<BaseLayout title="眠海">
  <LobbySketch slot="stage" />

  <article class="tint-dune">
    <header>
      <h1 class="enter" style="--i: 0;">眠&nbsp;海</h1>
      <p class="sub enter" style="--i: 1;">SUNKEN KEEP / 保持沉没</p>
    </header>

    <div class="banner-wrap enter" style={`--i: 2; --banner-h: ${BANNER_H}px;`}>
      <CineBanner
        sources={["/banner/lobby/lamp.mp4"]}
        height={BANNER_H}
        blur={6}
      />
    </div>

    <ul class="sketches">
      {entries.map((s, idx) => (
        <li class:list={['enter', { 'is-draft': s.draft }]} style={`--i: ${idx + 3};`}>
          <a href={s.href} data-heat-trigger>
            <div class="row">
              <span class="title">{s.title}</span>
              <span class="date">{s.date}</span>
            </div>
            <p class="summary">{s.summary}</p>
            <span class="kind">— {s.kind}{s.draft && <span class="draft-tag"> · 草稿</span>}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<script>
  function attachHeat() {
    for (const a of document.querySelectorAll<HTMLElement>('[data-heat-trigger]')) {
      a.addEventListener('mouseenter', () => {
        window.dispatchEvent(new CustomEvent('stage:heat', { detail: { level: 1 } }));
      });
      a.addEventListener('mouseleave', () => {
        window.dispatchEvent(new CustomEvent('stage:heat', { detail: { level: 0 } }));
      });
    }
  }

  // The banner pins center-aligned to the header. The pin position is
  // pure CSS: `top: calc(... + var(--header-h)/2 - var(--banner-h)/2)`.
  // JS only writes --header-h via ResizeObserver, which fires on every
  // layout shift that can change header height: font swap, breakpoint
  // crossing, viewport resize, even mobile chrome show/hide. No scroll
  // listener, no cached offsets — that's what made the previous version
  // brittle.
  function trackHeaderHeight() {
    const header = document.querySelector<HTMLElement>('article > header');
    if (!header) return;
    const tracked = header as HTMLElement & { __hRO?: ResizeObserver };
    if (tracked.__hRO) return;

    const root = document.documentElement;
    const ro = new ResizeObserver((entries) => {
      const e = entries[0];
      const h = e.borderBoxSize?.[0]?.blockSize ?? e.contentRect.height;
      root.style.setProperty('--header-h', `${h}px`);
    });
    ro.observe(header);
    tracked.__hRO = ro;

    // SPA nav swaps the article DOM — disconnect so we don't leak
    // observers across pages. astro:page-load on the new page will
    // re-run this function and attach a fresh observer.
    document.addEventListener('astro:before-swap', () => {
      ro.disconnect();
    }, { once: true });
  }

  attachHeat();
  trackHeaderHeight();
  document.addEventListener('astro:page-load', () => {
    attachHeat();
    trackHeaderHeight();
  });
</script>

<style>
  /* === Sticky header + banner ===
     Stack order (front → back):
       30  header           — solid bg, pinned at top: 5rem (matches column padding-top)
       20  .banner-wrap     — pinned center-aligned with header; isolated stacking context
            ├ 0 .cine-banner    — banner content (default in wrap context)
            ├ 0 ::before        — solid mask above banner (no overlap with .cine-banner — spatially separate)
            └ 0 ::after         — gradient fade below banner (ditto)
       (default) sketches list  — scrolls underneath both pinned layers
       2   .column::before/::after — desktop column edge feathers (BaseLayout); below header/banner
       9999 .grain               — film-grain overlay (above everything, intentional)

     The pin position is pure CSS — `top: calc(...)` reads --header-h from
     a ResizeObserver and --banner-h from an inline style on .banner-wrap.
     No JS scroll listener, no cached offsets. */

  /* --header-offset is the y-coordinate at which the header pins. It
     defaults to the column's padding-top (5rem on desktop, overridden
     in portrait to sit below the stage canvas). Setting it equal to
     the header's natural top makes sticky engage from scrollY=0 — no
     pre-pin movement. */
  article {
    --header-offset: 5rem;
  }
  header {
    position: sticky;
    top: var(--header-offset);
    z-index: 30;
    margin-bottom: 1.5em;
    padding-bottom: 0.5em;
  }
  .banner-wrap {
    position: sticky;
    /* Center-line align with header: banner_center = header_center.
       max() guards against the rare case where header is taller than
       banner (would otherwise pin above viewport top). */
    top: max(0px, calc(var(--header-offset) + var(--header-h, 0px) / 2 - var(--banner-h, 0px) / 2));
    z-index: 20;
    isolation: isolate;
    margin-bottom: 2.5em;
  }
  /* Solid mask above the banner: covers any content that scrolls up
     into the strip behind the header. Height 100vh so even at extreme
     viewport heights or rubber-band scroll, the top edge never appears. */
  .banner-wrap::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: -3rem;
    right: -3rem;
    height: 100vh;
    background: var(--bg);
    pointer-events: none;
  }
  /* Gradient fade below the banner: list items reappear softly as they
     scroll out from under the banner. Negative left/right cancels the
     column's horizontal padding so the mask is full column width. */
  .banner-wrap::after {
    content: '';
    position: absolute;
    top: 100%;
    left: -3rem;
    right: -3rem;
    height: 4em;
    background: linear-gradient(var(--bg), transparent);
    pointer-events: none;
  }

  /* Mobile portrait: single-column layout with .stage pinned at top:0
     (height 30svh, z-index 1). Shift --header-offset so header pins at
     stage_bottom + column_padding_top — that equals the header's
     natural y, so it pins from scrollY=0 with zero movement. Banner
     follows the same center-line math via the var. ::before's 100vh
     upward extent must be capped to the stage→banner gap, otherwise
     it would paint over the stage canvas (banner-wrap z=20 sits above
     stage z=1). */
  @media (max-width: 860px) and (orientation: portrait) {
    article {
      --header-offset: calc(var(--stage-h-mobile, 30svh) + 2rem);
    }
    .banner-wrap::before {
      height: max(0px, calc(2rem + (var(--header-h, 0px) - var(--banner-h, 0px)) / 2));
    }
    .banner-wrap::before,
    .banner-wrap::after {
      left: -1.5rem;
      right: -1.5rem;
    }
  }

  ul.sketches {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.35em;
    font-size: 2.6rem;
    margin: 0;
    padding-left: 0.35em;
    line-height: 1.2;
  }
  .sub {
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--muted);
    letter-spacing: 0.3em;
    margin: 0.9em 0 0;
    padding-left: 0.3em;
    font-size: 0.72rem;
  }
  ul.sketches li {
    padding: 1.8em 0;
    border-bottom: 1px solid var(--rule);
  }
  ul.sketches a {
    display: block;
    text-decoration: none;
  }
  ul.sketches .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
  }
  ul.sketches a:hover .title {
    color: var(--accent);
  }
  .title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    transition: color 200ms ease;
  }
  .date {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .summary {
    margin: 0.5em 0 0.4em;
    color: var(--fg-dim);
    font-size: 0.95rem;
  }
  .kind {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 0.65rem;
    color: var(--accent);
  }
  /* Draft entries appear only in dev (PROD filters them out). The marker
     sits on the kind line — same scale as the rest of the meta so it
     doesn't shout — and the row anchor dims slightly so a quick scan
     can tell drafts and shipped pieces apart at a glance. The dim is on
     the <a>, not the <li>, because the <li>'s `.enter` keyframe pins
     opacity = 1 with animation-fill-mode: both. */
  ul.sketches li.is-draft a {
    opacity: 0.55;
    transition: opacity 200ms ease;
  }
  ul.sketches li.is-draft a:hover {
    opacity: 1;
  }
  .draft-tag {
    color: var(--muted);
  }
</style>
