---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbySketch from '../components/LobbySketch.astro';
import CineBanner from '../components/CineBanner.astro';
import { getCollection } from 'astro:content';
import { SKETCHES } from '../lib/sketches';

// Sketches remain hand-authored .astro pages (their layouts are bespoke,
// so a shared template fights them). The registry lives in src/lib/sketches.ts
// so each sketch page can import `isDraft` and gate itself in PROD.
// `draft` is uniform with the essay shape below so the listing template
// can render the "草稿" marker without caring which collection it came from.
const sketches = SKETCHES
  .filter((s) => import.meta.env.DEV || s.published)
  .map((s) => ({ ...s, draft: !s.published }));

// Long-form essays come from the content collection.
const essayEntries = await getCollection('essays', (e) => import.meta.env.DEV || e.data.published);
const essays = essayEntries.map((e) => ({
  href: `/essays/${e.id}/`,
  title: e.data.title,
  date: e.data.date,
  kind: e.data.kind,
  summary: e.data.summary,
  draft: !e.data.published,
}));

// Date desc, tie-break by href so order is deterministic. Essays sort
// before sketches on the same date because 'essays/' < 'sketches/'.
const entries = [...sketches, ...essays].sort((a, b) => {
  if (a.date !== b.date) return a.date < b.date ? 1 : -1;
  return a.href < b.href ? -1 : 1;
});

// Single source of truth: the same px feeds both the CineBanner prop
// and the CSS var that the banner-wrap's sticky `top` calc consumes.
const BANNER_H = 120;
---

<BaseLayout title="眠海">
  {/* Force the home page to load at scrollY=0. Astro's ClientRouter
      restores scroll on every load (incl. refresh) by reading
      history.state.scrollY at module-init time — history.state survives
      reloads, so disabling browser scrollRestoration alone isn't
      enough. This inline classic script runs synchronously during
      parsing, before any module executes, and zeroes the saved
      position so ClientRouter's restore is a no-op. The pinned banner
      + .enter animation + eased pre-pin curve form a fragile dance
      at scrollY=0; restoring mid-pin races them. */}
  <script is:inline>
    if (history.state && (history.state.scrollX || history.state.scrollY)) {
      history.replaceState({ ...history.state, scrollX: 0, scrollY: 0 }, '');
    }
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  </script>

  <LobbySketch slot="stage" />

  <article class="tint-dune">
    <header>
      <h1 class="enter" style="--i: 0;">眠&nbsp;海</h1>
      <p class="sub enter" style="--i: 1;">SUNKEN KEEP / 保持沉没</p>
    </header>

    {/* No `.enter` class on the banner-wrap. The fade-in's initial
        keyframe (opacity: 0 with animation-fill-mode: both) can strand
        the banner invisible if the timeline ever pauses or stalls —
        view transitions on SPA nav back from a sketch can do that
        intermittently, even with init's classList.remove('enter')
        firing synchronously. Dropping the class entirely removes the
        race; h1 / .sub / list items still get their staggered reveal.

        Also no transition:name on banner-wrap. With a name, the
        banner becomes its own view-transition pseudo, lifted out of
        the root snapshot. During the cross-fade that means the
        banner's pseudo (50% alpha mid-fade) and the root pseudo (also
        50%, with the banner-region now showing list items beneath
        because banner was extracted) overlap — you see the list
        items through the half-transparent banner. Keeping the banner
        in the root snapshot bakes the layering into a single flat
        image, so banner / header text / list pixels fade together
        as one unit and nothing peeks through. */}
    <div class="banner-wrap" style={`--banner-h: ${BANNER_H}px;`}>
      <CineBanner
        sources={["/banner/lobby/lamp.mp4"]}
        height={BANNER_H}
        blur={6}
      />
    </div>

    <ul class="sketches">
      {entries.map((s, idx) => (
        <li class:list={['enter', { 'is-draft': s.draft }]} style={`--i: ${idx + 3};`}>
          <a href={s.href} data-heat-trigger>
            <div class="row">
              <span class="title">{s.title}</span>
              <span class="date">{s.date}</span>
            </div>
            <p class="summary">{s.summary}</p>
            <span class="kind">— {s.kind}{s.draft && <span class="draft-tag"> · 草稿</span>}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<script>
  function attachHeat() {
    for (const a of document.querySelectorAll<HTMLElement>('[data-heat-trigger]')) {
      a.addEventListener('mouseenter', () => {
        window.dispatchEvent(new CustomEvent('stage:heat', { detail: { level: 1 } }));
      });
      a.addEventListener('mouseleave', () => {
        window.dispatchEvent(new CustomEvent('stage:heat', { detail: { level: 0 } }));
      });
    }
  }

  // The banner pins center-aligned to the header. The pin position is
  // pure CSS: `top: calc(... + var(--header-h)/2 - var(--banner-h)/2)`.
  // JS only writes --header-h via ResizeObserver, which fires on every
  // layout shift that can change header height: font swap, breakpoint
  // crossing, viewport resize, even mobile chrome show/hide. No scroll
  // listener, no cached offsets — that's what made the previous version
  // brittle.
  function trackHeaderHeight() {
    const header = document.querySelector<HTMLElement>('article > header');
    if (!header) return;
    const tracked = header as HTMLElement & { __hRO?: ResizeObserver };
    if (tracked.__hRO) return;

    const root = document.documentElement;
    const ro = new ResizeObserver((entries) => {
      const e = entries[0];
      const h = e.borderBoxSize?.[0]?.blockSize ?? e.contentRect.height;
      root.style.setProperty('--header-h', `${h}px`);
    });
    ro.observe(header);
    tracked.__hRO = ro;

    // SPA nav swaps the article DOM — disconnect so we don't leak
    // observers across pages. astro:page-load on the new page will
    // re-run this function and attach a fresh observer.
    document.addEventListener('astro:before-swap', () => {
      ro.disconnect();
    }, { once: true });
  }

  // Bend the banner's pre-pin travel from linear (sticky's default) to
  // ease-in-out, so it visibly slows as it lifts off natural and again
  // as it settles into pin. Lenis already smooths the scroll itself;
  // this curve is applied on top so the *banner's* progress through its
  // travel is non-linear regardless of input speed.
  //
  // Math: at scrollY S in [0, pinDist], smoothstep gives the eased
  // progress p; the banner's eased viewport y is naturalY - p*pinDist,
  // and sticky's actual is naturalY - S, so the delta we apply via
  // translate is pinDist * (t - p) where t = S/pinDist. Outside the
  // pre-pin range the delta is 0 (sticky alone is correct).
  let bannerEaseCleanup: (() => void) | null = null;

  function bannerEase() {
    bannerEaseCleanup?.();
    bannerEaseCleanup = null;

    const banner = document.querySelector<HTMLElement>('.banner-wrap');
    if (!banner) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const init = () => {
      // Same .enter-class trick as before: animation-fill-mode: both
      // would lock translateY(0) over our inline transform forever.
      banner.classList.remove('enter');

      let pinDist = 0;
      let raf = 0;
      let stopped = false;

      const measure = () => {
        const pinY = parseFloat(getComputedStyle(banner).top) || 0;
        let natY = 0;
        let el: HTMLElement | null = banner;
        while (el) {
          natY += el.offsetTop;
          el = el.offsetParent as HTMLElement | null;
        }
        pinDist = Math.max(0, natY - pinY);
      };

      // Cached once at init: the title participates in the same scroll
      // curve via a CSS variable that drives a mask-image gradient (see
      // h1's CSS rule). Setting it on the element directly keeps the
      // var local — no global pollution.
      const titleEl = document.querySelector<HTMLElement>('article > header > h1');

      const apply = () => {
        if (stopped) return;
        const s = window.scrollY;
        let progress = 0;
        if (pinDist <= 0 || s <= 0) {
          banner.style.transform = '';
        } else if (s >= pinDist) {
          banner.style.transform = '';
          progress = 1;
        } else {
          const t = s / pinDist;
          progress = t * t * (3 - 2 * t);
          banner.style.transform = `translate3d(0, ${pinDist * (t - progress)}px, 0)`;
        }
        if (titleEl) titleEl.style.setProperty('--p', String(progress));
        raf = 0;
      };

      const onScroll = () => {
        if (!raf && !stopped) raf = requestAnimationFrame(apply);
      };

      measure();
      apply();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Layout shifts (font swap, header height change, breakpoint) move
      // the natural and pin positions; recompute and re-apply.
      const ro = new ResizeObserver(() => {
        measure();
        apply();
      });
      ro.observe(banner);
      ro.observe(document.documentElement);
      // Header height feeds banner's pin y via --header-h. Observing
      // the header catches resize events that move the pin (font swap,
      // breakpoint) which the banner/documentElement ROs miss because
      // neither of those elements actually resizes.
      const header = document.querySelector<HTMLElement>('article > header');
      if (header) ro.observe(header);

      bannerEaseCleanup = () => {
        stopped = true;
        if (raf) cancelAnimationFrame(raf);
        window.removeEventListener('scroll', onScroll);
        ro.disconnect();
        banner.style.transform = '';
      };
    };

    // Run init immediately rather than waiting on the .enter
    // animation's `finished` Promise. The wait was originally there to
    // sidestep animation-fill-mode locking transform after completion,
    // but init's first line removes the .enter class which cancels the
    // animation regardless of state — same effect, no race. The wait
    // could leave the banner invisible if the animation never reaches
    // its end frame (paused tab during SPA nav back, view transition
    // suspending the timeline, etc.), since opacity: 0 from .enter's
    // initial keyframe is retained while finished hasn't resolved.
    // Trade-off: banner skips the fade-in entry; h1 / sub / list still
    // get theirs from .enter on those elements.
    init();
  }

  attachHeat();
  trackHeaderHeight();
  bannerEase();
  document.addEventListener('astro:page-load', () => {
    attachHeat();
    trackHeaderHeight();
    bannerEase();
  });
</script>

<style>
  /* === Sticky header + banner ===
     Stack order (front → back):
       30  header           — solid bg, pinned at top: 5rem (matches column padding-top)
       20  .banner-wrap     — pinned center-aligned with header; isolated stacking context
            ├ 0 .cine-banner    — banner content (default in wrap context)
            ├ 0 ::before        — solid mask above banner (no overlap with .cine-banner — spatially separate)
            └ 0 ::after         — gradient fade below banner (ditto)
       (default) sketches list  — scrolls underneath both pinned layers
       2   .column::before/::after — desktop column edge feathers (BaseLayout); below header/banner
       9999 .grain               — film-grain overlay (above everything, intentional)

     The pin position is pure CSS — `top: calc(...)` reads --header-h from
     a ResizeObserver and --banner-h from an inline style on .banner-wrap.
     No JS scroll listener, no cached offsets. */

  /* --header-offset is the y-coordinate at which the header pins. It
     defaults to the column's padding-top (5rem on desktop, overridden
     in portrait to sit below the stage canvas). Setting it equal to
     the header's natural top makes sticky engage from scrollY=0 — no
     pre-pin movement. */
  article {
    --header-offset: 5rem;
  }
  header {
    position: sticky;
    top: var(--header-offset);
    z-index: 30;
    margin-bottom: 2em;
    padding-bottom: 0.5em;
  }
  .banner-wrap {
    position: sticky;
    /* Center-line align with header: banner_center = header_center.
       max() guards against the rare case where header is taller than
       banner (would otherwise pin above viewport top). */
    top: max(0px, calc(var(--header-offset) + var(--header-h, 0px) / 2 - var(--banner-h, 0px) / 2));
    z-index: 20;
    isolation: isolate;
    margin-bottom: 2.5em;
    /* Break out partway past the column's 3rem horizontal padding —
       wider than the text it backs (so it reads as a background plate
       when it pins behind the header) but with breathing room before
       reaching the column's outer edge. The mask/fade pseudo-elements
       inherit this width via left/right: 0. */
    margin-left: -2rem;
    margin-right: -2rem;
  }
  /* Solid mask above the banner: covers any content that scrolls up
     into the strip behind the header. Height 100vh so even at extreme
     viewport heights or rubber-band scroll, the top edge never appears.
     Bottom extends 1px *into* the banner so sub-pixel rendering of the
     pin position (calc lands on fractional px) can't expose a hairline
     gap between mask and banner. */
  .banner-wrap::before {
    content: '';
    position: absolute;
    bottom: calc(100% - 1px);
    left: 0;
    right: 0;
    height: 100vh;
    background: var(--bg);
    pointer-events: none;
  }
  /* Gradient fade below the banner: list items reappear softly as they
     scroll out from under the banner. banner-wrap is already extended
     to the column's outer edges via negative margins, so left/right: 0
     gives full column width. */
  .banner-wrap::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 4em;
    background: linear-gradient(var(--bg), transparent);
    pointer-events: none;
  }

  /* Mobile portrait: single-column layout with .stage pinned at top:0
     (height 30svh, z-index 1). Shift --header-offset so header pins at
     stage_bottom + column_padding_top — that equals the header's
     natural y, so it pins from scrollY=0 with zero movement. Banner
     follows the same center-line math via the var. ::before's 100vh
     upward extent must be capped to the stage→banner gap, otherwise
     it would paint over the stage canvas (banner-wrap z=20 sits above
     stage z=1). */
  @media (max-width: 860px) and (orientation: portrait) {
    article {
      --header-offset: calc(var(--stage-h-mobile, 30svh) + 2rem);
    }
    /* Mobile column padding is 1.5rem; scale the break-out down
       proportionally to keep the same partial-extension feel. */
    .banner-wrap {
      margin-left: -1rem;
      margin-right: -1rem;
    }
    .banner-wrap::before {
      height: max(0px, calc(2rem + (var(--header-h, 0px) - var(--banner-h, 0px)) / 2));
    }
  }

  ul.sketches {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.35em;
    font-size: 2.6rem;
    margin: 0;
    line-height: 1.2;
    /* Title sinks into the banner as it pins. JS writes --p (0 =
       banner at natural / scrollY=0, 1 = banner fully pinned) on
       every scroll frame; two stops in the mask gradient interpolate
       toward more aggressive fade values. At p=1 the top 30% stays
       solid, 30%–90% gradient-fades, and 90%–100% is fully
       transparent. At p=0 both stops park well past 100% so the
       visible 0–100% mask area is solid black throughout. */
    --p: 0;
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000,
      #000 calc(30% + 70% * (1 - var(--p))),
      transparent calc(90% + 110% * (1 - var(--p)))
    );
    mask-image: linear-gradient(
      to bottom,
      #000,
      #000 calc(30% + 70% * (1 - var(--p))),
      transparent calc(90% + 110% * (1 - var(--p)))
    );
  }
  .sub {
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--muted);
    letter-spacing: 0.3em;
    margin: 0.9em 0 0;
    font-size: 0.72rem;
  }
  ul.sketches li {
    padding: 1.8em 0;
    border-bottom: 1px solid var(--rule);
  }
  ul.sketches a {
    display: block;
    text-decoration: none;
  }
  ul.sketches .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
  }
  ul.sketches a:hover .title {
    color: var(--accent);
  }
  .title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    transition: color 200ms ease;
  }
  .date {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .summary {
    margin: 0.5em 0 0.4em;
    color: var(--fg-dim);
    font-size: 0.95rem;
  }
  .kind {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 0.65rem;
    color: var(--accent);
  }
  /* Draft entries appear only in dev (PROD filters them out). The marker
     sits on the kind line — same scale as the rest of the meta so it
     doesn't shout — and the row anchor dims slightly so a quick scan
     can tell drafts and shipped pieces apart at a glance. The dim is on
     the <a>, not the <li>, because the <li>'s `.enter` keyframe pins
     opacity = 1 with animation-fill-mode: both. */
  ul.sketches li.is-draft a {
    opacity: 0.55;
    transition: opacity 200ms ease;
  }
  ul.sketches li.is-draft a:hover {
    opacity: 1;
  }
  .draft-tag {
    color: var(--muted);
  }
</style>
