              </layer></staff>
              <harm place="above" staff="1" tstamp="1">Dm7</harm>
              <harm place="above" staff="1" tstamp="3">G7</harm>
              <harm place="below" staff="1" tstamp="1">ii</harm>
              <harm place="below" staff="1" tstamp="3">V7</harm>
