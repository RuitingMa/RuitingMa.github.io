            <!-- Bar 8 — in the sky, ii-V-I cadence -->
            <measure n="8">
              <staff n="1"><layer n="1">
                <note pname="e" oct="4" dur="4"/>
                <note pname="e" oct="4" dur="4"/>
                <note pname="d" oct="4" dur="4"/>
