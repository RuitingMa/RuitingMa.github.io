<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Chrome stress test — every axis swaps wildly, including mid-measure</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0" midi.bpm="92">
            <staffGrp symbol="brace" bar.thru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2"/>
              <staffDef n="2" lines="5" clef.shape="F" clef.line="4"/>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- m1: baseline. C major, 4/4, treble + bass. -->
            <measure n="1">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
                <note pname="g" oct="5" dur="4"/>
                <note pname="c" oct="6" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="c" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
                <note pname="c" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m2: keysig → 2 sharps (D major), meter → 3/4. -->
            <scoreDef key.sig="2s" meter.count="3" meter.unit="4"/>
            <measure n="2">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="f" oct="5" accid.ges="s" dur="4"/>
                <note pname="a" oct="5" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="d" oct="3" dur="4"/>
                <note pname="a" oct="3" dur="4"/>
                <note pname="d" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m3: staff 2 → alto clef (C on line 3), keysig 4 sharps. -->
            <scoreDef key.sig="4s" meter.count="4" meter.unit="4">
              <staffGrp>
                <staffDef n="2" lines="5" clef.shape="C" clef.line="3"/>
              </staffGrp>
            </scoreDef>
            <measure n="3">
              <staff n="1"><layer n="1">
                <note pname="e" oct="5" dur="4"/>
                <note pname="g" oct="5" accid.ges="s" dur="4"/>
                <note pname="b" oct="5" dur="4"/>
                <note pname="e" oct="6" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="b" oct="3" dur="4"/>
                <note pname="d" oct="4" accid.ges="s" dur="4"/>
                <note pname="b" oct="3" dur="4"/>
                <note pname="d" oct="4" accid.ges="s" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m4: 3/4. Mid-measure clef change in staff 1 (G → F). -->
            <scoreDef meter.count="3" meter.unit="4"/>
            <measure n="4">
              <staff n="1"><layer n="1">
                <note pname="g" oct="5" accid.ges="s" dur="4"/>
                <clef shape="F" line="4"/>
                <note pname="g" oct="3" dur="4"/>
                <note pname="b" oct="3" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="g" oct="3" dur="4"/>
                <note pname="b" oct="3" dur="4"/>
                <note pname="d" oct="4" accid.ges="s" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m5: keysig stays 4#, meter 4/4, both staves swap mid-measure. -->
            <scoreDef meter.count="4" meter.unit="4">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="F" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="5">
              <staff n="1"><layer n="1">
                <note pname="c" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
                <clef shape="G" line="2"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="g" oct="5" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="b" oct="3" dur="4"/>
                <clef shape="F" line="4"/>
                <note pname="d" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
                <note pname="d" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m6: 6 flats (G♭ major), 5/8. -->
            <scoreDef key.sig="6f" meter.count="5" meter.unit="8">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="G" clef.line="2"/>
                <staffDef n="2" lines="5" clef.shape="F" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="6">
              <staff n="1"><layer n="1">
                <note pname="g" oct="5" accid.ges="f" dur="8"/>
                <note pname="b" oct="5" accid.ges="f" dur="8"/>
                <note pname="d" oct="6" accid.ges="f" dur="8"/>
                <note pname="g" oct="5" accid.ges="f" dur="8"/>
                <note pname="b" oct="5" accid.ges="f" dur="8"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
                <note pname="d" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
                <note pname="d" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
              </layer></staff>
            </measure>

            <!-- m7: 6/8. Rapid mid-measure clef alternation in staff 1. -->
            <scoreDef meter.count="6" meter.unit="8"/>
            <measure n="7">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="8"/>
                <clef shape="F" line="4"/>
                <note pname="c" oct="3" dur="8"/>
                <clef shape="G" line="2"/>
                <note pname="c" oct="5" dur="8"/>
                <clef shape="C" line="3"/>
                <note pname="c" oct="4" dur="8"/>
                <clef shape="G" line="2"/>
                <note pname="g" oct="5" dur="8"/>
                <note pname="c" oct="6" dur="8"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
                <note pname="d" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
                <note pname="d" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="2" accid.ges="f" dur="8"/>
                <note pname="d" oct="3" accid.ges="f" dur="8"/>
              </layer></staff>
            </measure>

            <!-- m8: 7 sharps (C# major), 7/8. -->
            <scoreDef key.sig="7s" meter.count="7" meter.unit="8"/>
            <measure n="8">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" accid.ges="s" dur="8"/>
                <note pname="d" oct="5" accid.ges="s" dur="8"/>
                <note pname="e" oct="5" accid.ges="s" dur="8"/>
                <note pname="f" oct="5" accid.ges="s" dur="8"/>
                <note pname="g" oct="5" accid.ges="s" dur="8"/>
                <note pname="a" oct="5" accid.ges="s" dur="8"/>
                <note pname="b" oct="5" accid.ges="s" dur="8"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="d" oct="3" accid.ges="s" dur="8"/>
                <note pname="e" oct="3" accid.ges="s" dur="8"/>
                <note pname="f" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="a" oct="3" accid.ges="s" dur="8"/>
                <note pname="b" oct="3" accid.ges="s" dur="8"/>
              </layer></staff>
            </measure>

            <!-- m9: C major, 4/4, both staves to alto/tenor C clef. -->
            <scoreDef key.sig="0" meter.count="4" meter.unit="4">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="C" clef.line="3"/>
                <staffDef n="2" lines="5" clef.shape="C" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="9">
              <staff n="1"><layer n="1">
                <note pname="b" oct="3" dur="4"/>
                <note pname="d" oct="4" dur="4"/>
                <note pname="f" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="g" oct="3" dur="4"/>
                <note pname="b" oct="3" dur="4"/>
                <note pname="d" oct="4" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m10: 3 flats (E♭ major). Staff 2 mid-measure clef storm. -->
            <scoreDef key.sig="3f"/>
            <measure n="10">
              <staff n="1"><layer n="1">
                <note pname="e" oct="4" accid.ges="f" dur="4"/>
                <note pname="g" oct="4" dur="4"/>
                <note pname="b" oct="4" accid.ges="f" dur="4"/>
                <note pname="e" oct="5" accid.ges="f" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="e" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="3" dur="8"/>
                <clef shape="G" line="2"/>
                <note pname="b" oct="4" accid.ges="f" dur="8"/>
                <note pname="e" oct="5" accid.ges="f" dur="8"/>
                <clef shape="F" line="4"/>
                <note pname="b" oct="3" accid.ges="f" dur="8"/>
                <note pname="e" oct="3" accid.ges="f" dur="8"/>
                <note pname="g" oct="3" dur="8"/>
                <note pname="b" oct="3" accid.ges="f" dur="8"/>
              </layer></staff>
            </measure>

            <!-- m11: 12/8, 5 sharps. -->
            <scoreDef key.sig="5s" meter.count="12" meter.unit="8">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="G" clef.line="2"/>
                <staffDef n="2" lines="5" clef.shape="F" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="11">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" accid.ges="s" dur="8"/>
                <note pname="d" oct="5" accid.ges="s" dur="8"/>
                <note pname="e" oct="5" dur="8"/>
                <note pname="f" oct="5" accid.ges="s" dur="8"/>
                <note pname="g" oct="5" accid.ges="s" dur="8"/>
                <note pname="a" oct="5" accid.ges="s" dur="8"/>
                <note pname="b" oct="5" dur="8"/>
                <note pname="c" oct="6" accid.ges="s" dur="8"/>
                <note pname="d" oct="6" accid.ges="s" dur="8"/>
                <note pname="e" oct="6" dur="8"/>
                <note pname="d" oct="6" accid.ges="s" dur="8"/>
                <note pname="c" oct="6" accid.ges="s" dur="8"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
                <note pname="c" oct="3" accid.ges="s" dur="8"/>
                <note pname="g" oct="3" accid.ges="s" dur="8"/>
              </layer></staff>
            </measure>

            <!-- m12: every axis swaps. C → 1f, 12/8 → 4/4, alto + bass clefs. -->
            <scoreDef key.sig="1f" meter.count="4" meter.unit="4">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="C" clef.line="3"/>
                <staffDef n="2" lines="5" clef.shape="F" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="12">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="f" oct="5" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="f" oct="2" dur="4"/>
                <note pname="c" oct="3" dur="4"/>
                <note pname="f" oct="2" dur="4"/>
                <note pname="c" oct="3" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m13: mid-measure: meter doesn't, but every staff hops clefs twice. -->
            <scoreDef key.sig="2f"/>
            <measure n="13">
              <staff n="1"><layer n="1">
                <clef shape="G" line="2"/>
                <note pname="b" oct="4" accid.ges="f" dur="8"/>
                <note pname="e" oct="5" accid.ges="f" dur="8"/>
                <clef shape="F" line="4"/>
                <note pname="b" oct="2" accid.ges="f" dur="8"/>
                <note pname="e" oct="3" accid.ges="f" dur="8"/>
                <clef shape="C" line="3"/>
                <note pname="b" oct="3" accid.ges="f" dur="8"/>
                <note pname="d" oct="4" dur="8"/>
                <clef shape="G" line="2"/>
                <note pname="b" oct="4" accid.ges="f" dur="8"/>
                <note pname="d" oct="5" dur="8"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <clef shape="G" line="2"/>
                <note pname="g" oct="4" dur="4"/>
                <clef shape="F" line="4"/>
                <note pname="g" oct="2" dur="4"/>
                <note pname="d" oct="3" dur="4"/>
                <note pname="g" oct="2" dur="4"/>
              </layer></staff>
            </measure>

            <!-- m14: home key + meter, both staves naturally back to default. -->
            <scoreDef key.sig="0" meter.count="4" meter.unit="4">
              <staffGrp>
                <staffDef n="1" lines="5" clef.shape="G" clef.line="2"/>
                <staffDef n="2" lines="5" clef.shape="F" clef.line="4"/>
              </staffGrp>
            </scoreDef>
            <measure n="14">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
                <note pname="g" oct="5" dur="4"/>
                <note pname="c" oct="6" dur="4"/>
              </layer></staff>
              <staff n="2"><layer n="1">
                <note pname="c" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
                <note pname="c" oct="3" dur="4"/>
                <note pname="g" oct="3" dur="4"/>
              </layer></staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
